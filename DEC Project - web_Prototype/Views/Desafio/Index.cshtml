@model List<DEC.Models.Desafio>

@{
    ViewData["Title"] = "Desafios";
    var user = ViewBag.User as DEC.Models.User;
}

<div class="container">
    <div class="flex justify-between align-center mb-3">
        <h1>Desafios Pedagógicos</h1>
        @if (user.Role == DEC.Models.UserRole.Professor || user.Role == DEC.Models.UserRole.Administrador)
        {
            <a class="btn btn-primary" asp-action="Create">+ Novo Desafio</a>
        }
    </div>

    @if (Model != null && Model.Any())
    {
        @foreach (var desafio in Model)
        {
            var nivelClass = desafio.Nivel == DEC.Models.NivelDificuldade.Facil ? "nivel-facil" :
                           desafio.Nivel == DEC.Models.NivelDificuldade.Medio ? "nivel-medio" : "nivel-dificil";

            var nivelColor = desafio.Nivel == DEC.Models.NivelDificuldade.Facil ? "#28a745" :
                           desafio.Nivel == DEC.Models.NivelDificuldade.Medio ? "#ffc107" : "#dc3545";

            <div class="desafio-card" style="border-left-color: @nivelColor;">
                <div class="flex justify-between align-center mb-2">
                    <div class="flex align-center gap-2">
                        <h3 style="margin: 0;">@desafio.Titulo</h3>
                        <span class="desafio-nivel @nivelClass">@desafio.Nivel</span>
                    </div>
                    <span class="badge badge-primary" style="font-size: 1rem; padding: 0.5rem 1rem;">@desafio.Pontos pontos</span>
                </div>

                <p style="margin-bottom: 1rem; color: #666;">@desafio.Descricao</p>

                @if (!string.IsNullOrEmpty(desafio.ObjetivoAprendizagem))
                {
                    <div style="padding: 1rem; background: #f8f9fa; border-left: 3px solid var(--istec-blue); margin-bottom: 1rem;">
                        <strong style="color: var(--istec-blue);">Objetivo de Aprendizagem:</strong>
                        <p style="margin: 0.5rem 0 0 0;">@desafio.ObjetivoAprendizagem</p>
                    </div>
                }

                <div class="flex justify-between align-center">
                    <small style="color: #999;">Criado em @desafio.DataCriacao.ToString("dd/MM/yyyy")</small>

                    <div class="flex gap-1">
                        <a class="btn btn-primary btn-small" asp-action="Details" asp-route-id="@desafio.Id">Ver Detalhes</a>

                        @if (user.Role == DEC.Models.UserRole.Professor || user.Role == DEC.Models.UserRole.Administrador)
                        {
                            <a class="btn btn-secondary btn-small" asp-action="Edit" asp-route-id="@desafio.Id">Editar</a>
                            <form asp-action="Delete" asp-route-id="@desafio.Id" method="post" style="display: inline;" onsubmit="return confirm('Tem a certeza que deseja desativar este desafio?');">
                                <button type="submit" class="btn btn-danger btn-small">Desativar</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="card" style="text-align: center; padding: 4rem;">
            <h3 style="color: #666; margin-bottom: 1rem;">Não há desafios disponíveis</h3>
            @if (user.Role == DEC.Models.UserRole.Professor || user.Role == DEC.Models.UserRole.Administrador)
            {
                <p style="color: #999; margin-bottom: 2rem;">Crie o primeiro desafio para os seus alunos</p>
                <a class="btn btn-primary" asp-action="Create">Criar Desafio</a>
            }
            else
            {
                <p style="color: #999;">Os professores ainda não criaram desafios</p>
            }
        </div>
    }
</div>
