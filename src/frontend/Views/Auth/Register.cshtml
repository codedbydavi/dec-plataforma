@model Frontend.Models.RegisterViewModel

@{
    ViewData["Title"] = "Register";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DEC</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="login-bg page-fade-in">

<div class="container d-flex flex-column align-items-center">
    <div class="mb-4 align-self-start ms-lg-5" style="max-width: 450px; width: 100%; margin: 0 auto;">
        <a asp-controller="Home" asp-action="Index" class="text-white text-decoration-none d-inline-flex align-items-center opacity-75 hover-opacity-100 transition-all">
            <i class="bi bi-arrow-left-circle fs-4 me-2"></i>
            <span>Back to Home</span>
        </a>
    </div>

    <div class="card login-card shadow-lg p-4 p-sm-5">
        <div class="text-center mb-4">
            <div class="d-inline-flex align-items-center justify-content-center bg-success bg-gradient text-white rounded-circle mb-3" style="width: 60px; height: 60px;">
                <i class="bi bi-person-plus fs-2"></i>
            </div>
            <h2 class="fw-bold text-dark">Join DEC</h2>
            <p class="text-muted small">Start your financial literacy journey</p>
        </div>

        <form asp-action="Register" method="post" class="flex-grow-1 d-flex flex-column justify-content-center">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

            <div class="form-floating mb-2">
                <input asp-for="Name" class="form-control border-0 bg-light" placeholder="Full Name" id="regName" />
                <label asp-for="Name" for="regName">
                    <i class="bi bi-card-heading me-2"></i> Full Name
                </label>
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-2">
                <input asp-for="Username" class="form-control border-0 bg-light" placeholder="Username" id="regUser" />
                <label asp-for="Username" for="regUser">
                    <i class="bi bi-person me-2"></i> Username
                </label>
                <span asp-validation-for="Username" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-2">
                <input asp-for="Email" class="form-control border-0 bg-light" placeholder="Email" id="regEmail" />
                <label asp-for="Email" for="regEmail">
                    <i class="bi bi-envelope me-2"></i> Email
                </label>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-2">
                <input asp-for="Password" class="form-control border-0 bg-light" placeholder="Password" id="regPass" />
                <label asp-for="Password" for="regPass">
                    <i class="bi bi-lock me-2"></i> Password
                </label>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="ConfirmPassword" class="form-control border-0 bg-light" placeholder="Confirm Password" id="regConfirm" />
                <label asp-for="ConfirmPassword" for="regConfirm">
                    <i class="bi bi-shield-check me-2"></i> Confirm Password
                </label>
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <div class="d-grid mb-3">
                <button type="submit" class="btn btn-success py-3 rounded-3 shadow-sm fw-bold border-0" style="background: linear-gradient(to right, #11998e, #38ef7d);">
                    Create Account <i class="bi bi-check2-circle ms-2"></i>
                </button>
            </div>

            <div class="text-center">
                <p class="mb-0 text-muted small">Already have an account?</p>
                <a asp-action="Login" class="fw-bold text-primary text-decoration-none">Sign In</a>
            </div>
        </form>
    </div>
    
    <div class="text-center mt-4">
        <p class="text-white-50 small mb-0">&copy; 2026 DEC - Money at Home</p>
    </div>
</div>

<style>
    .transition-all { transition: all 0.2s ease-in-out; }
    .hover-opacity-100:hover { opacity: 1 !important; transform: translateX(-3px); }
</style>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

</body>
</html>
