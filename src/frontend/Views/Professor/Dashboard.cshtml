@model IEnumerable<Frontend.Models.DTOs.ClassGroupDto>

@{
    ViewData["Title"] = "Professor Dashboard";
}

<div class="container mt-4 page-fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>My Classes</h1>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createClassModal">Create New Class</button>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            You haven't created any classes yet. Start by creating one to invite your students.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var classGroup in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm h-100 border-primary border-top border-4">
                        <div class="card-body">
                            <h5 class="card-title fw-bold text-dark">@classGroup.Name</h5>
                            <h6 class="card-subtitle mb-3 text-muted">Join Code: <span class="badge bg-primary text-white fs-6">@classGroup.Join_Code</span></h6>
                            <p class="card-text mb-1">
                                <i class="bi bi-people-fill text-secondary me-2"></i> @classGroup.Student_Count Enrolled Students
                            </p>
                            <p class="card-text text-muted small">
                                <i class="bi bi-calendar-event text-secondary me-2"></i> Created on: @classGroup.Created_At.ToString("MM/dd/yyyy")
                            </p>
                        </div>
                        <div class="card-footer bg-transparent border-0 pt-0">
                            <a asp-action="ClassDetails" asp-route-id="@classGroup.Id" class="btn btn-outline-primary btn-sm w-100">View Details / Students</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Create Class Modal -->
<div class="modal fade" id="createClassModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="CreateClass" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">Create New Class</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="form-floating mb-3">
                        <input name="name" type="text" class="form-control" id="classNameInput" placeholder="Class Name" required />
                        <label for="classNameInput">Class Name (e.g., 10th Grade Math)</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Class</button>
                </div>
            </form>
        </div>
    </div>
</div>
