@model IEnumerable<Frontend.Models.Entities.Challenge>
@using Frontend.Models.Entities

@{
    ViewData["Title"] = "Desafios Financeiros";
    var myScenarios = (IEnumerable<Scenario>)ViewBag.MyScenarios;
    var completedChallenges = Model.Where(c => myScenarios != null && myScenarios.Any(s => s.ChallengeId == c.Id)).ToList();
    var activeChallenges = Model.Where(c => myScenarios == null || !myScenarios.Any(s => s.ChallengeId == c.Id)).ToList();
}

<div class="max-w-6xl mx-auto p-6">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-3xl mb-2 font-bold">Desafios Financeiros</h1>
            <p class="text-gray-500">
                Completa desafios práticos e recebe feedback do teu professor
            </p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">@TempData["SuccessMessage"]</span>
        </div>
    }

    <div class="grid md:grid-cols-3 gap-4 mb-8">
        <div class="bg-white rounded-xl border p-6 shadow-sm">
            <p class="text-sm text-gray-500 mb-2">Desafios Ativos</p>
            <div class="text-3xl font-bold flex items-center gap-2">
                <i data-lucide="clock" class="w-6 h-6 text-primary"></i>
                @activeChallenges.Count
            </div>
        </div>

        <div class="bg-white rounded-xl border p-6 shadow-sm">
            <p class="text-sm text-gray-500 mb-2">Desafios Entregues</p>
            <div class="text-3xl font-bold flex items-center gap-2">
                <i data-lucide="check-circle-2" class="w-6 h-6 text-green-500"></i>
                @completedChallenges.Count
            </div>
        </div>

        <div class="bg-white rounded-xl border p-6 shadow-sm">
            <p class="text-sm text-gray-500 mb-2">Média de Pontuação</p>
            <div class="text-3xl font-bold flex items-center gap-2">
                <i data-lucide="award" class="w-6 h-6 text-yellow-500"></i>
                @{
                    var evaluations = myScenarios?.SelectMany(s => s.Histories).Where(h => h.Score.HasValue).Select(h => h.Score!.Value).ToList();
                    var avg = evaluations?.Any() == true ? evaluations.Average() : 0;
                }
                @avg.ToString("F1")
            </div>
        </div>
    </div>

    <!-- Tabs -->
    <div class="mb-6 border-b border-gray-200">
        <ul class="flex flex-wrap -mb-px text-sm font-medium text-center" id="myTab" role="tablist">
            <li class="mr-2" role="presentation">
                <button class="inline-block p-4 border-b-2 border-primary text-primary rounded-t-lg active" id="active-tab" data-tabs-target="#active" type="button" role="tab">
                    Desafios Ativos (@activeChallenges.Count)
                </button>
            </li>
            <li class="mr-2" role="presentation">
                <button class="inline-block p-4 border-b-2 border-transparent hover:text-gray-600 hover:border-gray-300 rounded-t-lg" id="completed-tab" data-tabs-target="#completed" type="button" role="tab">
                    Concluídos (@completedChallenges.Count)
                </button>
            </li>
        </ul>
    </div>

    <div id="myTabContent">
        <!-- Active Challenges -->
        <div class="p-4 rounded-lg space-y-4" id="active" role="tabpanel">
            @if (!activeChallenges.Any())
            {
                <div class="bg-white rounded-xl border p-12 text-center shadow-sm">
                    <i data-lucide="target" class="w-16 h-16 mx-auto mb-4 text-gray-400"></i>
                    <p class="text-gray-500">Nenhum desafio ativo no momento</p>
                </div>
            }
            else
            {
                @foreach (var challenge in activeChallenges)
                {
                    <div class="bg-white rounded-xl border p-6 shadow-sm hover:shadow-md transition-shadow">
                        <div class="flex items-start justify-between">
                            <div class="flex-1">
                                <h3 class="text-lg font-bold flex items-center gap-2 mb-2">
                                    <i data-lucide="target" class="w-5 h-5 text-primary"></i>
                                    @challenge.Name
                                </h3>
                                <p class="text-gray-500 mb-4">@challenge.Description</p>
                                
                                <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500">
                                    <div class="flex items-center gap-1">
                                        <i data-lucide="calendar" class="w-4 h-4"></i>
                                        Prazo: Sem limite
                                    </div>
                                    <a href="@challenge.AccessLink" target="_blank" class="text-primary hover:underline flex items-center gap-1">
                                        <i data-lucide="external-link" class="w-4 h-4"></i>
                                        Aceder ao material
                                    </a>
                                    <button data-modal-target="submitModal-@challenge.Id" class="bg-primary text-white px-4 py-1.5 rounded-md font-bold hover:bg-primary/90 flex items-center gap-2">
                                        <i data-lucide="send" class="w-4 h-4"></i> Entregar Trabalho
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Submit Modal -->
                    <div id="submitModal-@challenge.Id" class="hidden fixed inset-0 bg-black/50 z-[100] flex items-center justify-center">
                        <div class="bg-white rounded-xl shadow-xl w-full max-w-md overflow-hidden">
                            <form asp-action="SubmitChallenge" method="post">
                                <input type="hidden" name="challengeId" value="@challenge.Id" />
                                <div class="px-6 py-4 border-b">
                                    <h3 class="text-lg font-bold">Entregar: @challenge.Name</h3>
                                </div>
                                <div class="p-6 space-y-4">
                                    <p class="text-sm text-gray-500">Escolha o cenário financeiro que criou para responder a este desafio:</p>
                                    <select name="scenarioId" class="w-full border rounded-md px-3 py-2 focus:ring-primary/50" required>
                                        <option value="">-- Selecionar Cenário --</option>
                                        @if (myScenarios != null)
                                        {
                                            @foreach (var sc in myScenarios.Where(s => !s.ChallengeId.HasValue))
                                            {
                                                <option value="@sc.Id">@sc.FamilyName (@sc.InitialBalance.ToString("C"))</option>
                                            }
                                        }
                                    </select>
                                    <div class="bg-blue-50 p-3 rounded text-xs text-blue-700">
                                        <strong>Nota:</strong> Certifique-se de que já executou a simulação no seu cenário antes de entregar.
                                    </div>
                                </div>
                                <div class="px-6 py-4 bg-gray-50 flex justify-end gap-3">
                                    <button type="button" onclick="document.getElementById('submitModal-@challenge.Id').classList.add('hidden')" class="px-4 py-2 border rounded-md hover:bg-gray-100 font-medium">Cancelar</button>
                                    <button type="submit" class="px-4 py-2 bg-primary text-white rounded-md hover:bg-primary/90 font-medium">Confirmar Entrega</button>
                                </div>
                            </form>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- Completed Challenges -->
        <div class="hidden p-4 rounded-lg space-y-4" id="completed" role="tabpanel">
            @if (!completedChallenges.Any())
            {
                <div class="bg-white rounded-xl border p-12 text-center shadow-sm">
                    <i data-lucide="trophy" class="w-16 h-16 mx-auto mb-4 text-gray-400"></i>
                    <p class="text-gray-500">Ainda não completaste nenhum desafio</p>
                </div>
            }
            else
            {
                @foreach (var challenge in completedChallenges)
                {
                    var submission = myScenarios.First(s => s.ChallengeId == challenge.Id);
                    var evaluation = submission.Histories.OrderByDescending(h => h.Id).FirstOrDefault();
                    
                    <div class="bg-white rounded-xl border p-6 shadow-sm border-l-4 border-green-500">
                        <div class="flex items-start justify-between">
                            <div class="flex-1">
                                <h3 class="text-lg font-bold flex items-center gap-2 mb-1">
                                    <i data-lucide="check-circle" class="w-5 h-5 text-green-500"></i>
                                    @challenge.Name
                                </h3>
                                <p class="text-sm text-gray-500 mb-3">Entregue com o cenário: <strong>@submission.FamilyName</strong></p>
                                
                                @if (evaluation?.Score != null)
                                {
                                    <div class="bg-gray-50 p-4 rounded-lg border">
                                        <p class="text-xs font-bold text-gray-400 uppercase mb-2">Feedback do Professor</p>
                                        <p class="text-gray-700 italic">"@evaluation.Feedback"</p>
                                    </div>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1 text-xs font-medium text-blue-600 bg-blue-50 px-2 py-1 rounded">
                                        <i data-lucide="info" class="w-3 h-3"></i> Aguarda avaliação
                                    </span>
                                }
                            </div>
                            
                            @if (evaluation?.Score != null)
                            {
                                <div class="text-right ml-4">
                                    <p class="text-xs text-gray-400 font-bold uppercase">Nota</p>
                                    <p class="text-3xl font-black text-primary">@evaluation.Score</p>
                                    <p class="text-xs text-gray-400">/ 20</p>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const tabs = document.querySelectorAll('[data-tabs-target]');
        const tabContents = document.querySelectorAll('[role="tabpanel"]');

        tabs.forEach(tab => {
            tab.addEventListener('click', () => {
                const target = document.querySelector(tab.dataset.tabsTarget);
                
                tabContents.forEach(tc => tc.classList.add('hidden'));
                tabs.forEach(t => {
                    t.classList.remove('border-primary', 'text-primary');
                    t.classList.add('border-transparent');
                });
                
                target.classList.remove('hidden');
                tab.classList.remove('border-transparent');
                tab.classList.add('border-primary', 'text-primary');
            });
        });
    </script>
}
