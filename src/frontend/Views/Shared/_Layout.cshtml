<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - DEC</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* Force full height and remove scroll */
        html, body {
            height: 100%;
            margin: 0;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        main {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden; /* Main content handles its own overflow if needed, but we aim for zero scroll */
        }

        .navbar { z-index: 1030; }
        .footer { z-index: 1030; }

        @@media (max-width: 768px) {
            .navbar-brand { font-size: 1.2rem; }
        }
    </style>
</head>
<body class="bg-light page-fade-in">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark py-2 shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-wallet2 text-primary me-2"></i> DEC
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse">
                    <ul class="navbar-nav me-auto">
                        @if (User.Identity?.IsAuthenticated == true) {
                            @if (User.IsInRole("Professor")) {
                                <li class="nav-item"><a class="nav-link px-3 text-info fw-bold" asp-controller="Professor" asp-action="Dashboard"><i class="bi bi-speedometer2 me-2"></i>Professor Panel</a></li>
                            }
                            @if (User.IsInRole("Student")) {
                                <li class="nav-item"><a class="nav-link px-3 text-info fw-bold" asp-controller="Student" asp-action="Dashboard"><i class="bi bi-house-door me-2"></i>My Dashboard</a></li>
                            }
                        } else {
                            <li class="nav-item"><a class="nav-link px-3" asp-controller="Home" asp-action="Index">Home</a></li>
                        }
                    </ul>
                    <ul class="navbar-nav align-items-center">
                        @if (User.Identity?.IsAuthenticated == true) {
                            <li class="nav-item dropdown bg-secondary bg-opacity-25 rounded-pill px-2">
                                <a class="nav-link dropdown-toggle text-white d-flex align-items-center" href="#" id="userDrop" data-bs-toggle="dropdown">
                                    <span class="badge bg-primary me-2">@User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value</span>
                                    <span>@User.Identity.Name</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                                    <li><a class="dropdown-item py-2" href="#"><i class="bi bi-person me-2"></i> Profile</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Auth" asp-action="Logout" method="post" class="px-3 py-1">
                                            <button type="submit" class="btn btn-sm btn-danger w-100 rounded-pill">Logout</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        } else {
                            <li class="nav-item"><a class="btn btn-outline-light btn-sm rounded-pill px-3 me-2" asp-controller="Auth" asp-action="Login">Login</a></li>
                            <li class="nav-item"><a class="btn btn-primary btn-sm rounded-pill px-3 shadow-sm" asp-controller="Auth" asp-action="Register">Register</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer py-2 bg-dark text-white-50 border-top border-secondary border-opacity-25">
        <div class="container">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center small text-center text-md-start">
                <div>
                    <span class="text-white fw-bold">DEC</span>
                    <span class="ms-1 opacity-75">| Money at Home</span>
                </div>
                <div class="mt-1 mt-md-0">
                    <a asp-controller="Home" asp-action="Privacy" class="text-white-50 text-decoration-none me-2">Privacy Policy</a>
                    <span class="opacity-50">| ISTEC Porto - Institutions</span>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
