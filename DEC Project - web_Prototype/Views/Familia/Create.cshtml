@model DEC.Models.Familia

@{
    ViewData["Title"] = "Nova Família";
}

<div class="container">
    <h1 class="mb-3">Criar Nova Família</h1>

    <div class="card">
        <form asp-action="Create" method="post">
            <h3 style="margin-bottom: 1.5rem; color: var(--istec-blue);">Informações Básicas</h3>

            <div class="form-group">
                <label class="form-label">Nome da Família *</label>
                <input type="text" asp-for="Nome" class="form-control" placeholder="Ex: Família Silva" required />
            </div>

            <div class="form-group">
                <label class="form-label">Descrição</label>
                <textarea asp-for="Descricao" class="form-control" rows="3" placeholder="Descreva o contexto familiar..."></textarea>
            </div>

            <div class="grid-2">
                <div class="form-group">
                    <label class="form-label">Número de Adultos *</label>
                    <input type="number" asp-for="NumeroAdultos" class="form-control" min="1" value="2" required />
                </div>

                <div class="form-group">
                    <label class="form-label">Número de Crianças</label>
                    <input type="number" asp-for="NumeroCriancas" class="form-control" min="0" value="0" />
                </div>
            </div>

            <h3 style="margin: 2rem 0 1.5rem; color: var(--istec-blue);">Valores Iniciais (Opcional)</h3>
            <p style="color: #666; margin-bottom: 1.5rem;">Pode adicionar valores iniciais ou registar transações mais tarde</p>

            <div class="grid-2">
                <div class="form-group">
                    <label class="form-label">Rendimento Mensal (€)</label>
                    <input type="number" asp-for="RendimentoMensal" class="form-control" min="0" step="0.01" value="0" />
                </div>

                <div class="form-group">
                    <label class="form-label">Poupança Inicial (€)</label>
                    <input type="number" asp-for="Poupanca" class="form-control" min="0" step="0.01" value="0" />
                </div>
            </div>

            <div class="grid-2">
                <div class="form-group">
                    <label class="form-label">Despesas Fixas (€)</label>
                    <input type="number" asp-for="DespesasFixas" class="form-control" min="0" step="0.01" value="0" />
                    <small style="color: #666;">Renda, créditos, seguros, etc.</small>
                </div>

                <div class="form-group">
                    <label class="form-label">Despesas Variáveis (€)</label>
                    <input type="number" asp-for="DespesasVariaveis" class="form-control" min="0" step="0.01" value="0" />
                    <small style="color: #666;">Alimentação, transporte, lazer, etc.</small>
                </div>
            </div>

            <div class="form-group">
                <label class="form-check-label">
                    <input type="checkbox" asp-for="Ativa" checked /> Família Ativa
                </label>
            </div>

            <div class="flex gap-1 mt-3">
                <button type="submit" class="btn btn-primary">Criar Família</button>
                <a class="btn btn-secondary" asp-action="Index">Cancelar</a>
            </div>
        </form>
    </div>
</div>
