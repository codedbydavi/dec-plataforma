@model Frontend.Models.Entities.Classroom

@{
    ViewData["Title"] = $"Turma: {Model.Name}";
    var assignedChallenges = (IEnumerable<Frontend.Models.Entities.ChallengeAssignment>)ViewBag.AssignedChallenges;
}

<div class="max-w-7xl mx-auto p-6">
    <!-- Breadcrumb -->
    <nav class="flex mb-6 text-sm" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-3">
            <li class="inline-flex items-center">
                <a asp-action="Dashboard" class="text-gray-500 hover:text-primary flex items-center gap-1">
                    <i data-lucide="layout-dashboard" class="w-4 h-4"></i> Dashboard
                </a>
            </li>
            <li>
                <div class="flex items-center">
                    <i data-lucide="chevron-right" class="w-4 h-4 text-gray-400"></i>
                    <span class="ml-1 font-medium text-gray-700">@Model.Name</span>
                </div>
            </li>
        </ol>
    </nav>

    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
        <div>
            <h1 class="text-3xl font-bold mb-1">@Model.Name</h1>
            <p class="text-gray-500">Gestão de alunos e avaliação de desempenho financeiro</p>
        </div>
        <div class="bg-white border rounded-xl p-4 flex items-center gap-4 shadow-sm">
            <div class="bg-blue-50 p-3 rounded-lg text-primary">
                <i data-lucide="key" class="w-6 h-6"></i>
            </div>
            <div>
                <p class="text-xs text-gray-500 uppercase font-bold tracking-wider">Código de Acesso</p>
                <p class="text-xl font-mono font-bold text-primary">@Model.MemberCode</p>
            </div>
        </div>
    </div>

    <div class="grid lg:grid-cols-3 gap-8">
        <!-- Students List -->
        <div class="lg:col-span-2 space-y-6">
            <div class="bg-white rounded-xl border shadow-sm overflow-hidden">
                <div class="p-6 border-b flex items-center justify-between">
                    <h3 class="font-bold text-lg flex items-center gap-2">
                        <i data-lucide="users" class="w-5 h-5 text-primary"></i>
                        Alunos Inscritos (@Model.Enrollments.Count)
                    </h3>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-sm text-left">
                        <thead class="bg-gray-50 text-gray-500 uppercase">
                            <tr>
                                <th class="px-6 py-3">Aluno</th>
                                <th class="px-6 py-3 text-center">Último Saldo</th>
                                <th class="px-6 py-3 text-center">Simulações</th>
                                <th class="px-6 py-3 text-right">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Enrollments.Any())
                            {
                                <tr>
                                    <td colspan="4" class="px-6 py-12 text-center text-gray-500">
                                        <i data-lucide="user-plus" class="w-12 h-12 mx-auto mb-3 opacity-20"></i>
                                        <p>Ainda não há alunos inscritos nesta turma.</p>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var enrollment in Model.Enrollments)
                                {
                                    var student = enrollment.Student;
                                    var latestScenario = student?.Scenarios.OrderByDescending(s => s.Id).FirstOrDefault();
                                    <tr class="border-b last:border-b-0 hover:bg-gray-50">
                                        <td class="px-6 py-4">
                                            <div class="flex items-center gap-3">
                                                <div class="w-10 h-10 rounded-full bg-primary/10 text-primary flex items-center justify-center font-bold">
                                                    @(student?.FullName?[0].ToString() ?? "?")
                                                </div>
                                                <div>
                                                    <p class="font-bold">@student?.FullName</p>
                                                    <p class="text-xs text-gray-500">@student?.Email</p>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4 text-center font-medium">
                                            @if (latestScenario != null)
                                            {
                                                <span>€@latestScenario.InitialBalance.ToString("N2")</span>
                                            }
                                            else
                                            {
                                                <span class="text-gray-400 text-xs">Sem cenários</span>
                                            }
                                        </td>
                                        <td class="px-6 py-4 text-center">
                                            <span class="bg-gray-100 text-gray-700 px-2.5 py-0.5 rounded-full text-xs font-medium">
                                                @(latestScenario?.Histories.Count ?? 0)
                                            </span>
                                        </td>
                                        <td class="px-6 py-4 text-right">
                                            @if (latestScenario?.Histories.Any() == true)
                                            {
                                                <button data-modal-target="evaluateModal-@enrollment.Id" class="text-primary font-bold hover:underline">
                                                    Avaliar
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="text-gray-300">Sem submissões</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Challenges Sidebar -->
        <div class="space-y-6">
            <div class="bg-white rounded-xl border shadow-sm p-6">
                <h3 class="font-bold text-lg mb-4 flex items-center gap-2">
                    <i data-lucide="target" class="w-5 h-5 text-secondary"></i>
                    Desafios da Turma
                </h3>
                <div class="space-y-3">
                    @if (assignedChallenges != null && assignedChallenges.Any())
                    {
                        @foreach (var assignment in assignedChallenges)
                        {
                            <div class="p-3 border rounded-lg bg-gray-50">
                                <p class="font-bold text-sm text-gray-800">@assignment.Challenge?.Name</p>
                                <p class="text-xs text-gray-500 mt-1 flex items-center gap-1">
                                    <i data-lucide="calendar" class="w-3 h-3"></i> Atribuído em @assignment.AssignedAt.ToString("dd/MM/yyyy")
                                </p>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-6 border-2 border-dashed rounded-lg">
                            <p class="text-xs text-gray-400">Nenhum desafio atribuído.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modals for Evaluation -->
@foreach (var enrollment in Model.Enrollments)
{
    var latestScenario = enrollment.Student?.Scenarios.OrderByDescending(s => s.Id).FirstOrDefault();
    if (latestScenario?.Histories.Any() == true)
    {
        var latestHistory = latestScenario.Histories.OrderByDescending(h => h.Id).First();
        <div id="evaluateModal-@enrollment.Id" class="hidden fixed inset-0 bg-black/50 z-[100] flex items-center justify-center">
            <div class="bg-white rounded-xl shadow-xl w-full max-w-lg overflow-hidden">
                <form asp-action="Evaluate" method="post">
                    <input type="hidden" name="historyId" value="@latestHistory.Id" />
                    <div class="px-6 py-4 border-b flex items-center justify-between">
                        <h3 class="text-lg font-bold">Avaliar Simulação: @enrollment.Student?.FullName</h3>
                        <button type="button" onclick="document.getElementById('evaluateModal-@enrollment.Id').classList.add('hidden')" class="text-gray-400 hover:text-gray-600">
                            <i data-lucide="x" class="w-5 h-5"></i>
                        </button>
                    </div>
                    <div class="p-6 space-y-4">
                        <div class="grid grid-cols-2 gap-4 bg-blue-50 p-4 rounded-lg border border-blue-100 mb-4">
                            <div>
                                <p class="text-xs text-blue-600 uppercase font-bold mb-1">Saldo Final</p>
                                <p class="text-lg font-bold">€@latestHistory.FinalBalance.ToString("N2")</p>
                            </div>
                            <div>
                                <p class="text-xs text-blue-600 uppercase font-bold mb-1">Taxa de Esforço</p>
                                <p class="text-lg font-bold">@latestHistory.EffortRate.ToString("F1")%</p>
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium mb-1">Pontuação (0-20)</label>
                            <input name="score" type="number" step="0.1" min="0" max="20" class="w-full border rounded-md px-3 py-2 focus:ring-primary/50" placeholder="Ex: 18.5" required value="@(latestHistory.Score ?? 0)" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-1">Feedback Pedagógico</label>
                            <textarea name="feedback" class="w-full border rounded-md px-3 py-2 focus:ring-primary/50" rows="4" placeholder="Excelente planeamento financeiro...">@latestHistory.Feedback</textarea>
                        </div>
                    </div>
                    <div class="px-6 py-4 bg-gray-50 flex justify-end gap-3">
                        <button type="button" onclick="document.getElementById('evaluateModal-@enrollment.Id').classList.add('hidden')" class="px-4 py-2 border rounded-md hover:bg-gray-100 font-medium">Cancelar</button>
                        <button type="submit" class="px-4 py-2 bg-primary text-white rounded-md hover:bg-primary/90 font-medium">Submeter Avaliação</button>
                    </div>
                </form>
            </div>
        </div>
    }
}

@section Scripts {
    <script>
        document.querySelectorAll('[data-modal-target]').forEach(btn => {
            btn.addEventListener('click', () => {
                const target = document.getElementById(btn.getAttribute('data-modal-target'));
                if (target) target.classList.remove('hidden');
            });
        });
    </script>
}
