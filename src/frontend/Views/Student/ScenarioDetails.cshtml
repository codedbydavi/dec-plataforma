        <form asp-action="EditEntry" method="post">
            <input type="hidden" name="id" id="editEntryId" />
            <div class="px-6 py-4 border-b flex justify-between items-center">
                <h3 class="text-lg font-bold">Editar Lançamento Financeiro</h3>
                <button type="button" class="text-gray-400 hover:text-gray-600" onclick="document.getElementById('editEntryModal').classList.add('hidden')"><i data-lucide="x" class="w-5 h-5"></i></button>
            </div>
            <div class="p-6 space-y-4">
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium mb-1">Tipo</label>
