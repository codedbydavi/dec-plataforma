</div>

@section Scripts {
    <script>
        function openEditEntryModal(id, typeId, categoryId, amount, month, recurrence) {
            document.getElementById('editEntryId').value = id;
            document.getElementById('editEntryType').value = typeId;
            document.getElementById('editEntryCategory').value = categoryId;
            document.getElementById('editEntryAmount').value = amount;
            document.getElementById('editEntryMonth').value = month;
            document.getElementById('editEntryRecurrence').checked = recurrence;
            
            document.getElementById('editEntryModal').classList.remove('hidden');
        }


        document.querySelectorAll('[data-modal-target]').forEach(btn => {
            btn.addEventListener('click', () => {
                const target = document.getElementById(btn.getAttribute('data-modal-target'));
                if (target) target.classList.remove('hidden');
            });
        });


        const tabs = document.querySelectorAll('[data-tabs-target]');
        const tabContents = document.querySelectorAll('[role="tabpanel"]');
        let chartsRendered = false;

        tabs.forEach(tab => {
            tab.addEventListener('click', () => {
                const target = document.querySelector(tab.dataset.tabsTarget);
                
                tabContents.forEach(tc => tc.classList.add('hidden'));
                tabs.forEach(t => {
                    t.classList.remove('border-primary', 'text-primary');
                    t.classList.add('border-transparent');
                });
                
                target.classList.remove('hidden');
                tab.classList.remove('border-transparent');
                tab.classList.add('border-primary', 'text-primary');

                if (tab.id === 'dashboard-tab' && !chartsRendered) {
                    renderCharts();
                    chartsRendered = true;
                }
            });
        });

        function renderCharts() {
            @if (lastResult != null) {
                <text>

                Chart.helpers.each(Chart.instances, function(instance){
                    instance.destroy();
                });


                new Chart(document.getElementById('chartIncomeExpenses'), {
                    type: 'doughnut',
                    data: {
                        labels: ['Rendimentos', 'Despesas'],
                        datasets: [{
                            data: [@lastResult.Summary.TotalMonthlyIncome.ToString().Replace(",", "."), @lastResult.Summary.TotalMonthlyExpenses.ToString().Replace(",", ".")],
                            backgroundColor: ['#16a34a', '#dc2626'],
                            borderWidth: 0
                        }]
                    },
                    options: { maintainAspectRatio: false, animation: false, plugins: { legend: { position: 'bottom' } } }
                });


                const initial = @scenario.InitialBalance.ToString().Replace(",", ".");
                const monthlyBalance = @lastResult.Summary.MonthlyBalance.ToString().Replace(",", ".");
                const labels = ['Agora', '1m', '2m', '3m', '4m', '5m', '6m', '7m', '8m', '9m', '10m', '11m', '12m'];
                const dataPoints = [];
                for (let i = 0; i <= 12; i++) {
                    dataPoints.push(initial + (monthlyBalance * i));
                }

                new Chart(document.getElementById('chartProjection'), {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Saldo Projetado',
                            data: dataPoints,
                            borderColor: '#0C73B7',
                            backgroundColor: 'rgba(12, 115, 183, 0.1)',
                            fill: true,
                            tension: 0.3
                        }]
                    },
                    options: { 
                        maintainAspectRatio: false,
                        animation: false,
                        scales: { y: { beginAtZero: false, ticks: { callback: value => '€' + value } } } 
                    }
                });


                const effortRate = @lastResult.Summary.EffortRatePercentage.ToString().Replace(",", ".");
                new Chart(document.getElementById('chartEffortRate'), {
                    type: 'bar',
                    data: {
                        labels: ['Taxa de Esforço Atual'],
                        datasets: [{
                            label: 'A tua taxa (%)',
                            data: [effortRate],
                            backgroundColor: effortRate > 40 ? '#dc2626' : '#16a34a',
                            barThickness: 30
                        }, {
                            label: 'Limite Saudável (40%)',
                            data: [40],
                            backgroundColor: '#eab308',
                            barThickness: 30
                        }]
                    },
                    options: { 
                        indexAxis: 'y',
                        maintainAspectRatio: false,
                        animation: false,
                        scales: { x: { max: 100, ticks: { callback: v => v + '%' } } }
                    }
                });
                </text>
                }
                }

                let formToSubmit = null;

                function showConfirmModal(formElement, message) {
                formToSubmit = formElement;
                if (message) {
                document.getElementById('confirmDeleteMessage').textContent = message;
                }
                document.getElementById('confirmDeleteModal').classList.remove('hidden');
                }

                function closeConfirmDeleteModal() {
                document.getElementById('confirmDeleteModal').classList.add('hidden');
                formToSubmit = null;
                }

                document.getElementById('confirmDeleteBtn').addEventListener('click', () => {
                if (formToSubmit) {
                formToSubmit.submit();
                }
                });
                </script>
                }

                <div id="confirmDeleteModal" class="hidden fixed inset-0 bg-black/50 z-[110] flex items-center justify-center p-4">
                <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm overflow-hidden animate-in zoom-in-95 duration-200">
                <div class="p-6 text-center">
                <div class="w-16 h-16 bg-red-50 rounded-full flex items-center justify-center mx-auto mb-4 text-red-600">
                <i data-lucide="trash-2" class="w-8 h-8"></i>
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">Confirmar Remoção</h3>
                <p id="confirmDeleteMessage" class="text-gray-500">Tens a certeza que desejas remover este item? Esta ação não pode ser desfeita.</p>
                </div>
                <div class="px-6 py-4 bg-gray-50 flex gap-3">
                <button type="button" onclick="closeConfirmDeleteModal()" class="flex-1 px-4 py-2.5 border-2 border-gray-200 rounded-xl hover:bg-white font-bold text-gray-600 transition-all text-sm">
                Cancelar
                </button>
                <button id="confirmDeleteBtn" type="button" class="flex-1 px-4 py-2.5 bg-red-600 text-white rounded-xl hover:bg-red-700 font-bold shadow-lg shadow-red-200 transition-all active:scale-95 text-sm">
                Remover
                </button>
                </div>
                </div>
                </div>