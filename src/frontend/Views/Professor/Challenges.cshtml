@model IEnumerable<Frontend.Models.Entities.Challenge>

@{
    ViewData["Title"] = "Gestão de Desafios";
}

<div class="max-w-6xl mx-auto p-6">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-3xl mb-2 font-bold">Gestão de Desafios</h1>
            <p class="text-gray-500">
                Cria e gere desafios para os teus alunos
            </p>
        </div>
        <button data-modal-target="createChallengeModal" class="inline-flex items-center gap-2 px-4 py-2 bg-primary text-white rounded-md font-medium hover:bg-primary/90">
            <i data-lucide="plus" class="w-4 h-4"></i> Criar Desafio
        </button>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">@TempData["SuccessMessage"]</span>
        </div>
    }

    <div class="grid md:grid-cols-3 gap-4 mb-8">
        <div class="bg-white rounded-xl border p-6 shadow-sm">
            <p class="text-sm text-gray-500 mb-2">Total de Desafios</p>
            <div class="text-3xl font-bold flex items-center gap-2">
                <i data-lucide="target" class="w-6 h-6 text-primary"></i>
                @Model.Count()
            </div>
        </div>
    </div>

    <!-- Active Challenges -->
    <div class="p-4 rounded-lg space-y-4" id="active" role="tabpanel">
        @if (!Model.Any())
        {
            <div class="bg-white rounded-xl border p-12 text-center shadow-sm">
                <i data-lucide="target" class="w-16 h-16 mx-auto mb-4 text-gray-400"></i>
                <p class="text-gray-500">Nenhum desafio criado ainda</p>
            </div>
        }
        else
        {
            @foreach (var challenge in Model)
            {
                <div class="bg-white rounded-xl border p-6 shadow-sm hover:shadow-md transition-shadow">
                    <div class="flex items-start justify-between">
                        <div class="flex-1">
                            <h3 class="text-lg font-bold flex items-center gap-2 mb-2">
                                <i data-lucide="target" class="w-5 h-5 text-primary"></i>
                                @challenge.Name
                            </h3>
                            <p class="text-gray-500 mb-4">@challenge.Description</p>
                            
                            <div class="flex items-center gap-4 text-sm text-gray-500">
                                <div class="flex items-center gap-1">
                                    <i data-lucide="calendar" class="w-4 h-4"></i>
                                    Criado em: @challenge.CreatedAt.ToString("dd/MM/yyyy")
                                </div>
                                <a href="@challenge.AccessLink" target="_blank" class="text-primary hover:underline flex items-center gap-1">
                                    <i data-lucide="external-link" class="w-4 h-4"></i>
                                    Aceder ao material
                                </a>
                            </div>
                        </div>
                        <span class="bg-gray-100 text-gray-800 text-xs font-medium px-2.5 py-0.5 rounded flex items-center ml-4">
                            <i data-lucide="award" class="w-3 h-3 mr-1"></i>
                            100 pts
                        </span>
                    </div>
                </div>
            }
        }
    </div>
</div>

<partial name="_CreateChallengeModal" model="ViewBag.Classes" />

@section Scripts {
    <script>
        document.querySelectorAll('[data-modal-target]').forEach(btn => {
            btn.addEventListener('click', () => {
                const target = document.getElementById(btn.getAttribute('data-modal-target'));
                if (target) target.classList.remove('hidden');
            });
        });
    </script>
}
