@model Frontend.Models.ViewModels.StudentDashboardViewModel

@{
    ViewData["Title"] = "Dashboard Aluno";
    var currentFamily = Model.SelectedScenario;
    var lastResult = Model.LatestResult;
    
    float totalIncome = 0;
    float totalExpenses = 0;
    float netIncome = 0;
    float effortRate = 0;
    float currentSavings = 0;
    float savingsGoal = 5000;
    float savingsProgress = 0;
    string categoryLabels = "[]";
    string categoryData = "[]";

    if (currentFamily != null)
    {
        totalIncome = currentFamily.Entries.Where(e => e is Frontend.Models.Entities.Income).Sum(e => e.Amount);
        totalExpenses = currentFamily.Entries.Where(e => e is Frontend.Models.Entities.Expense).Sum(e => e.Amount);
        
        if (lastResult != null)
        {
            netIncome = lastResult.Summary.MonthlyBalance;
            effortRate = lastResult.Summary.EffortRatePercentage;
        }
        else
        {
            netIncome = totalIncome - totalExpenses; 
            effortRate = totalIncome > 0 ? (totalExpenses / totalIncome) * 100 : 0; 
        }

        currentSavings = currentFamily.InitialBalance + netIncome;
        var firstObjective = currentFamily.Objectives.FirstOrDefault();
        savingsGoal = (float)(firstObjective?.TargetValue ?? 5000);
        savingsProgress = savingsGoal > 0 ? (currentSavings / savingsGoal) * 100 : 0;
        if (savingsProgress > 100) savingsProgress = 100;
        if (savingsProgress < 0) savingsProgress = 0;

        // Group expenses by category
        var expensesByCategory = currentFamily.Entries
            .Where(e => e is Frontend.Models.Entities.Expense)
            .GroupBy(e => e.Category?.Name ?? "Outros")
            .Select(g => new { Category = g.Key, Total = g.Sum(e => e.Amount) })
            .ToList();
            
        categoryLabels = System.Text.Json.JsonSerializer.Serialize(expensesByCategory.Select(c => c.Category));
        categoryData = System.Text.Json.JsonSerializer.Serialize(expensesByCategory.Select(c => c.Total));
    }
}

<div class="max-w-7xl mx-auto p-6">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">@TempData["SuccessMessage"]</span>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">@TempData["ErrorMessage"]</span>
        </div>
    }

    @if (currentFamily == null)
    {
        <div class="bg-white rounded-xl border p-12 text-center shadow-sm">
            <i data-lucide="target" class="w-16 h-16 mx-auto mb-4 text-gray-400"></i>
            <h2 class="text-2xl mb-4 font-bold">Bem-vindo ao DEC!</h2>
            <p class="text-gray-500 mb-6">
                Começa por criar o teu primeiro cenário familiar
            </p>
            <button data-modal-target="createScenarioModal" class="inline-flex items-center justify-center gap-2 px-4 py-2 bg-primary text-white rounded-md hover:bg-primary/90 font-medium">
                <i data-lucide="plus" class="w-4 h-4"></i> Criar Cenário Familiar
            </button>
        </div>
    }
    else
    {
        <div class="mb-8 flex flex-col md:flex-row md:items-center justify-between gap-4">
            <div>
                <h1 class="text-3xl mb-2 font-bold text-gray-900">Olá, @User.Identity?.Name!</h1>
                <p class="text-gray-500">
                    Aqui está o resumo financeiro do teu cenário.
                </p>
            </div>
            
            @if (Model.Scenarios.Count > 0)
            {
                <form method="get" asp-action="Dashboard" class="flex items-center gap-2">
                    <label for="scenarioId" class="text-sm font-medium text-gray-700">Família Analisada:</label>
                    <select id="scenarioId" name="scenarioId" onchange="this.form.submit()" class="border-gray-300 rounded-md shadow-sm focus:border-primary focus:ring-primary py-2 px-3 bg-white">
                        @foreach (var s in Model.Scenarios)
                        {
                            if (s.Id == currentFamily.Id)
                            {
                                <option value="@s.Id" selected>@s.FamilyName</option>
                            }
                            else
                            {
                                <option value="@s.Id">@s.FamilyName</option>
                            }
                        }
                    </select>
                </form>
            }
        </div>

        @if (lastResult == null && currentFamily.Entries.Any())
        {
            <div class="bg-yellow-50 border border-yellow-200 text-yellow-800 px-4 py-3 rounded-md mb-6 flex items-center gap-3">
                <i data-lucide="info" class="w-5 h-5 text-yellow-600"></i>
                <div class="text-sm">
                    Ainda não correste nenhuma simulação para esta família. <a asp-action="ScenarioDetails" asp-route-id="@currentFamily.Id" class="font-bold hover:underline">Corre o motor de cálculo agora.</a>
                </div>
            </div>
        }

        <!-- Key Metrics -->
        <div class="grid md:grid-cols-4 gap-4 mb-8">
            <div class="bg-white rounded-xl border p-6 shadow-sm">
                <p class="text-sm text-gray-500 mb-2">Saldo Mensal</p>
                <div class="text-2xl font-bold flex items-center gap-2">
                    €@netIncome.ToString("0.00")
                    <i data-lucide="trending-up" class="w-5 h-5 text-green-500"></i>
                </div>
            </div>

            <div class="bg-white rounded-xl border p-6 shadow-sm">
                <p class="text-sm text-gray-500 mb-2">Taxa de Esforço</p>
                <div class="text-2xl font-bold mb-2">@effortRate.ToString("0.0")%</div>
                <div class="w-full bg-gray-200 rounded-full h-2">
                    <div class="@(effortRate > 40 ? "bg-red-500" : "bg-primary") h-2 rounded-full" style="width: @Math.Min(effortRate, 100)%"></div>
                </div>
                <p class="text-xs text-gray-500 mt-2">@(effortRate > 40 ? "Atenção! Taxa elevada." : "Ótimo!")</p>
            </div>

            <div class="bg-white rounded-xl border p-6 shadow-sm">
                <p class="text-sm text-gray-500 mb-2">Poupança Inicial / Atual</p>
                <div class="text-2xl font-bold flex items-center gap-2">
                    <i data-lucide="piggy-bank" class="w-5 h-5 text-primary"></i>
                    €@currentSavings.ToString("0.00")
                </div>
            </div>

            <div class="bg-white rounded-xl border p-6 shadow-sm">
                <p class="text-sm text-gray-500 mb-2">Objetivo de Poupança</p>
                <div class="text-2xl font-bold mb-2">€@savingsGoal.ToString("N2")</div>
                <div class="w-full bg-gray-200 rounded-full h-2">
                    <div class="bg-primary h-2 rounded-full" style="width: @(savingsProgress)%"></div>
                </div>
            </div>
        </div>

        <!-- Charts Row -->
        <div class="grid md:grid-cols-2 gap-6 mb-8">
            <div class="bg-white rounded-xl border p-6 shadow-sm">
                <h3 class="font-bold text-lg mb-1">Evolução Mensal (Base)</h3>
                <p class="text-sm text-gray-500 mb-4">Rendimentos, despesas e poupança acumulada</p>
                <div class="relative h-[300px] w-full">
                    <canvas id="monthlyChart"></canvas>
                </div>
            </div>

            <div class="bg-white rounded-xl border p-6 shadow-sm">
                <h3 class="font-bold text-lg mb-1">Distribuição de Despesas</h3>
                <p class="text-sm text-gray-500 mb-4">Por categoria</p>
                <div class="relative h-[300px] w-full">
                    <canvas id="expensesChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Challenges and Achievements -->
        <div class="grid md:grid-cols-2 gap-6">
            <div class="bg-white rounded-xl border p-6 shadow-sm">
                <h3 class="font-bold text-lg mb-4 flex items-center gap-2">
                    <i data-lucide="target" class="text-primary w-5 h-5"></i> Desafios Ativos
                </h3>
                
                @if (!Model.Challenges.Any())
                {
                    <p class="text-gray-500 text-center py-4">Nenhum desafio ativo no momento</p>
                }
                else
                {
                    var myScenarios = Model.Scenarios;
                    var activeChallenges = Model.Challenges.Where(c => !myScenarios.Any(s => s.ChallengeId == c.Id)).ToList();

                    if (!activeChallenges.Any())
                    {
                        <p class="text-gray-500 text-center py-4">Todos os desafios concluídos!</p>
                    }
                    else
                    {
                        <div class="space-y-3">
                            @foreach (var challenge in activeChallenges.Take(3))
                            {
                                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg border">
                                    <div>
                                        <p class="font-medium">@challenge.Name</p>
                                        <p class="text-sm text-gray-500">100 pontos</p>
                                    </div>
                                    <a href="@challenge.AccessLink" target="_blank" class="px-3 py-1 bg-white border rounded text-sm hover:bg-gray-100">Ver</a>
                                </div>
                            }
                        </div>
                        <a asp-action="Challenges" class="block text-center w-full mt-4 px-4 py-2 border rounded-md hover:bg-gray-50 font-medium">
                            Ver Todos os Desafios
                        </a>
                    }
                }
            </div>

            <div class="bg-white rounded-xl border p-6 shadow-sm">
                <h3 class="font-bold text-lg mb-4 flex items-center gap-2">
                    <i data-lucide="award" class="text-primary w-5 h-5"></i> Conquistas
                </h3>
                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-gray-500 mb-2">Badges Conquistadas</p>
                        <div class="flex flex-wrap gap-2">
                            <span class="px-3 py-1.5 bg-yellow-50 text-yellow-800 border border-yellow-200 text-sm font-medium rounded-md">🏆 Iniciante Financeiro</span>
                            @if(lastResult != null && lastResult.Summary.EffortRatePercentage <= 30) {
                                <span class="px-3 py-1.5 bg-green-50 text-green-800 border border-green-200 text-sm font-medium rounded-md">🌟 Gestor Prudente</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="mt-8 flex flex-wrap gap-4">
            <a asp-action="ScenarioDetails" asp-route-id="@currentFamily.Id" class="px-4 py-2 bg-primary text-white rounded-md font-medium hover:bg-primary/90 shadow-sm transition-colors">
                Gerir Cenário e Correr Simulação
            </a>
            <a asp-action="Family" class="px-4 py-2 border border-gray-300 rounded-md font-medium hover:bg-gray-50 bg-white shadow-sm transition-colors">
                Meus Cenários
            </a>
        </div>
    }
</div>

<!-- Modal Create Scenario -->
<div id="createScenarioModal" class="hidden fixed inset-0 bg-black/50 z-[100] flex items-center justify-center">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-lg overflow-hidden">
        <form asp-action="CreateScenario" method="post">
            <div class="px-6 py-4 border-b">
                <h3 class="text-lg font-bold">Criar Cenário Familiar</h3>
            </div>
            <div class="p-6 space-y-4">
                <div>
                    <label class="block text-sm font-medium mb-1">Nome da Família</label>
                    <input name="FamilyName" type="text" class="w-full border rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-primary/50" required />
                </div>
                <div>
                    <label class="block text-sm font-medium mb-1">Saldo Inicial (€)</label>
                    <input name="InitialBalance" type="number" step="0.01" class="w-full border rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-primary/50" required />
                </div>
            </div>
            <div class="px-6 py-4 bg-gray-50 flex justify-end gap-3">
                <button type="button" onclick="document.getElementById('createScenarioModal').classList.add('hidden')" class="px-4 py-2 border rounded-md hover:bg-gray-100 font-medium">Cancelar</button>
                <button type="submit" class="px-4 py-2 bg-primary text-white rounded-md hover:bg-primary/90 font-medium">Criar Cenário</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Modal logic
            document.querySelectorAll('[data-modal-target]').forEach(btn => {
                btn.addEventListener('click', () => {
                    const target = document.getElementById(btn.getAttribute('data-modal-target'));
                    if (target) target.classList.remove('hidden');
                });
            });

            // Clean up existing Chart.js instances to avoid infinite loading / canvas reuse issues
            Chart.helpers.each(Chart.instances, function(instance){
                instance.destroy();
            });

            // Charts logic
            try {
                const monthlyChartCanvas = document.getElementById('monthlyChart');
                if (monthlyChartCanvas) {
                    const ctxMonthly = monthlyChartCanvas.getContext('2d');
                    
                    const baseIncome = parseFloat('@totalIncome.ToString().Replace(",", ".")') || 0;
                    const baseExpense = parseFloat('@totalExpenses.ToString().Replace(",", ".")') || 0;
                    let currentSav = parseFloat('@currentSavings.ToString().Replace(",", ".")') || 0;
                    
                    const savData = [];
                    for(let i=0; i<6; i++) {
                        savData.push(currentSav);
                        currentSav += (baseIncome - baseExpense);
                    }

                    new Chart(ctxMonthly, {
                        type: 'line',
                        data: {
                            labels: ['Mês 1', 'Mês 2', 'Mês 3', 'Mês 4', 'Mês 5', 'Mês 6'],
                            datasets: [
                                { label: 'Rendimentos', data: Array(6).fill(baseIncome), borderColor: '#0C73B7', backgroundColor: 'transparent', tension: 0.1 },
                                { label: 'Despesas', data: Array(6).fill(baseExpense), borderColor: '#d4183d', backgroundColor: 'transparent', tension: 0.1 },
                                { label: 'Poupança Acumulada', data: savData, borderColor: '#16a34a', backgroundColor: 'rgba(22, 163, 74, 0.1)', fill: true, tension: 0.1 }
                            ]
                        },
                        options: { 
                            responsive: true, 
                            maintainAspectRatio: false,
                            animation: false // Disable animation for better performance
                        }
                    });
                }
            } catch(e) { console.error('Erro no gráfico mensal:', e); }

            try {
                const expensesChartCanvas = document.getElementById('expensesChart');
                if (expensesChartCanvas) {
                    const ctxExpenses = expensesChartCanvas.getContext('2d');
                    
                    const catLabels = @Html.Raw(categoryLabels);
                    const catData = @Html.Raw(categoryData);
                    
                    new Chart(ctxExpenses, {
                        type: 'doughnut',
                        data: {
                            labels: catLabels && catLabels.length > 0 ? catLabels : ['Sem despesas registadas'],
                            datasets: [{
                                data: catData && catData.length > 0 ? catData : [1],
                                backgroundColor: ['#0C73B7', '#2da7df', '#4db8e8', '#f59e0b', '#dc2626', '#16a34a', '#8b5cf6'],
                                borderWidth: 0
                            }]
                        },
                        options: { 
                            responsive: true, 
                            maintainAspectRatio: false,
                            animation: false, // Disable animation
                            plugins: {
                                legend: {
                                    position: 'bottom'
                                }
                            }
                        }
                    });
                }
            } catch(e) { console.error('Erro no gráfico de despesas:', e); }
        });
    </script>
}
