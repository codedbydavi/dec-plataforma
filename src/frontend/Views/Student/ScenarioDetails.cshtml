@model Frontend.Models.ViewModels.ScenarioDetailsViewModel
@using System.Text.Json
@using Frontend.Models.DTOs

@{
    ViewData["Title"] = $"Scenario: {Model.Scenario.FamilyName} Family";
    var scenario = Model.Scenario;
    var lastResult = Model.LatestResult;
}

<div class="container-fluid px-4 mt-4 page-fade-in" style="height: calc(100vh - 120px); overflow-y: auto;">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-action="Dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active" aria-current="page">@scenario.FamilyName Family Scenario</li>
            </ol>
        </nav>
        <div class="btn-group shadow-sm">
            <button class="btn btn-outline-primary active" id="btnTables" onclick="showTab('tables')"><i class="bi bi-table me-2"></i>Data</button>
            <button class="btn btn-outline-primary" id="btnCharts" onclick="showTab('charts')"><i class="bi bi-pie-chart me-2"></i>Dashboard</button>
        </div>
    </div>

    <!-- Header Section -->
    <div class="card shadow-sm mb-4 border-primary border-top border-4">
        <div class="card-body d-flex justify-content-between align-items-center py-2">
            <div>
                <h3 class="card-title fw-bold text-primary mb-0">@scenario.FamilyName Family</h3>
                <p class="text-muted mb-0 small">Scenario ID: #@scenario.Id | Created: @scenario.CreatedAt.ToString("g")</p>
            </div>
            <div class="text-end d-flex align-items-center">
                <div class="me-4">
                    <h6 class="text-muted text-uppercase mb-0 small">Initial Balance</h6>
                    <h2 class="fw-bold mb-0">@scenario.InitialBalance.ToString("C")</h2>
                </div>
                <button class="btn btn-sm btn-outline-secondary rounded-circle" data-bs-toggle="modal" data-bs-target="#editScenarioModal" title="Edit Scenario">
                    <i class="bi bi-pencil"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Results Overview (Always Visible if lastResult exists) -->
    @if (lastResult != null)
    {
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card shadow-sm border-0 bg-primary text-white text-center">
                    <div class="card-body py-2">
                        <small class="text-white-50 text-uppercase d-block mb-0">Monthly Balance</small>
                        <h4 class="fw-bold mb-0">@lastResult.Summary.MonthlyBalance.ToString("C")</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-0 @(lastResult.Summary.EffortRatePercentage > 40 ? "bg-danger" : "bg-success") text-white text-center">
                    <div class="card-body py-2">
                        <small class="text-white-50 text-uppercase d-block mb-0">Effort Rate</small>
                        <h4 class="fw-bold mb-0">@lastResult.Summary.EffortRatePercentage.ToString("F1")%</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-0 bg-info text-white text-center">
                    <div class="card-body py-2">
                        <small class="text-white-50 text-uppercase d-block mb-0">12-Month Projection</small>
                        <h4 class="fw-bold mb-0">@lastResult.Projections.BalanceAfter12Months.ToString("C")</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-0 @(lastResult.Projections.IsSustainable ? "bg-success" : "bg-warning") text-white text-center">
                    <div class="card-body py-2">
                        <small class="text-white-50 text-uppercase d-block mb-0">Sustainability</small>
                        <h4 class="fw-bold mb-0">@(lastResult.Projections.IsSustainable ? "Sustainable" : "At Risk")</h4>
                    </div>
                </div>
            </div>
        </div>

        @if (lastResult.CreditSimulation != null)
        {
            <div class="alert alert-info border-0 shadow-sm mb-4 py-2 d-flex align-items-center">
                <i class="bi bi-bank fs-5 me-3"></i>
                <div class="small">
                    <strong>Credit Simulation Active:</strong> Monthly: <span class="fw-bold text-primary">@lastResult.CreditSimulation.MonthlyInstallment.ToString("C")</span> | 
                    Total Cost: <span class="fw-bold">@lastResult.CreditSimulation.TotalCost.ToString("C")</span> 
                    (Interest: @lastResult.CreditSimulation.TotalInterest.ToString("C"))
                </div>
            </div>
        }
    }

    <!-- Tab: Tables -->
    <div id="tabTables">
        <div class="row">
            <div class="col-lg-8 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center py-2 border-bottom">
                        <h5 class="mb-0 fw-bold"><i class="bi bi-list-columns-reverse text-primary me-2"></i>Financial Entries</h5>
                        <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#addEntryModal">
                            <i class="bi bi-plus-circle me-1"></i> Add
                        </button>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                            @if (!scenario.Entries.Any())
                            {
                                <div class="text-center p-5 text-muted">
                                    <i class="bi bi-journal-text fs-1 mb-3 d-block opacity-50"></i>
                                    <p>No financial entries yet.</p>
                                </div>
                            }
                            else
                            {
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light sticky-top">
                                        <tr>
                                            <th>Type</th>
                                            <th>Category</th>
                                            <th>Amount</th>
                                            <th>Month</th>
                                            <th>Recurring</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var entry in scenario.Entries.OrderBy(e => e.Month))
                                        {
                                            <tr>
                                                <td>
                                                    @if (entry is Frontend.Models.Entities.Income)
                                                    { <span class="badge bg-success">Income</span> }
                                                    else
                                                    { <span class="badge bg-danger">Expense</span> }
                                                </td>
                                                <td>@(entry.Category?.Name ?? "General")</td>
                                                <td class="fw-semibold">@entry.Amount.ToString("C")</td>
                                                <td>@entry.Month</td>
                                                <td>
                                                    @if (entry.Recurrence != "None" && entry.Recurrence != "False")
                                                    { <i class="bi bi-arrow-repeat text-info" title="@entry.Recurrence"></i> }
                                                    else
                                                    { <span class="text-muted small">One-off</span> }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 mb-4">
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center py-2 border-bottom">
                        <h5 class="mb-0 fw-bold"><i class="bi bi-bullseye text-success me-2"></i>Savings Goals</h5>
                        <button class="btn btn-sm btn-outline-success" data-bs-toggle="modal" data-bs-target="#addObjectiveModal">
                            <i class="bi bi-plus-circle"></i>
                        </button>
                    </div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush" style="max-height: 250px; overflow-y: auto;">
                            @if (!scenario.Objectives.Any())
                            {
                                <li class="list-group-item text-muted small text-center py-3">No goals defined.</li>
                            }
                            else
                            {
                                @foreach (var obj in scenario.Objectives)
                                {
                                    var analysis = lastResult?.ObjectivesAnalysis.FirstOrDefault(a => a.Description == obj.Description);
                                    <li class="list-group-item px-3 py-2">
                                        <div class="d-flex justify-content-between w-100">
                                            <h6 class="mb-0 fw-bold small">@obj.Description</h6>
                                            <span class="text-success fw-bold small">@obj.TargetValue.ToString("C")</span>
                                        </div>
                                        <div class="d-flex justify-content-between align-items-center mt-1">
                                            <small class="text-muted">In @obj.TargetMonths mo</small>
                                            @if (analysis != null)
                                            {
                                                <span class="badge @(analysis.IsAttainable ? "bg-success" : "bg-danger")" style="font-size: 0.65rem;">
                                                    @(analysis.IsAttainable ? $"Reach in {analysis.MonthsToGoal}mo" : "Unreachable")
                                                </span>
                                            }
                                        </div>
                                    </li>
                                }
                            }
                        </ul>
                    </div>
                </div>

                <div class="card shadow-sm border-0 bg-dark text-white text-center">
                    <div class="card-body py-3">
                        <i class="bi bi-calculator fs-3 mb-2 d-block text-warning"></i>
                        <h5 class="fw-bold mb-2">Simulation Engine</h5>
                        <div class="d-grid gap-2">
                            <form asp-action="RunSimulation" method="post">
                                <input type="hidden" name="scenarioId" value="@scenario.Id" />
                                <button type="submit" class="btn btn-warning fw-bold w-100 rounded-pill shadow-sm">
                                    Run Simulation <i class="bi bi-play-fill"></i>
                                </button>
                            </form>
                            <button class="btn btn-outline-info fw-bold rounded-pill btn-sm" data-bs-toggle="modal" data-bs-target="#creditSimModal">
                                Simulate Credit <i class="bi bi-bank"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Simulation History Section -->
        <div class="row mt-4">
            <div class="col-12">
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white py-2 border-bottom">
                        <h5 class="mb-0 fw-bold"><i class="bi bi-history text-secondary me-2"></i>Simulation History</h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-sm table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Date</th>
                                        <th>Final Balance (12m)</th>
                                        <th>Effort Rate</th>
                                        <th>Status</th>
                                        <th>Details</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!scenario.Histories.Any())
                                    {
                                        <tr><td colspan="5" class="text-center py-3 text-muted">No history available.</td></tr>
                                    }
                                    else
                                    {
                                        @foreach (var history in scenario.Histories.OrderByDescending(h => h.ExecutionDate))
                                        {
                                            <tr>
                                                <td class="small">@history.ExecutionDate.ToString("g")</td>
                                                <td class="fw-bold">@history.FinalBalance.ToString("C")</td>
                                                <td>
                                                    <span class="badge @(history.EffortRate > 40 ? "bg-danger" : "bg-success")">
                                                        @history.EffortRate.ToString("F1")%
                                                    </span>
                                                </td>
                                                <td>
                                                    @if (history.EffortRate <= 40)
                                                    { <span class="text-success small"><i class="bi bi-check-circle-fill me-1"></i>Sustainable</span> }
                                                    else
                                                    { <span class="text-warning small"><i class="bi bi-exclamation-triangle-fill me-1"></i>Risk</span> }
                                                </td>
                                                <td>
                                                    <button class="btn btn-link btn-sm p-0" title="View snapshot"><i class="bi bi-eye"></i></button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div id="tabCharts" style="display: none;">
        @if (lastResult == null)
        {
            <div class="card card-body text-center py-5 shadow-sm">
                <i class="bi bi-graph-up display-4 text-muted opacity-25 mb-3"></i>
                <h4 class="text-muted">No Simulation Data</h4>
                <p>Run a simulation to generate the visual dashboard.</p>
            </div>
        }
        else
        {
            <div class="row g-4">
                <div class="col-lg-6">
                    <div class="card shadow-sm h-100">
                        <div class="card-header bg-white py-2"><h6 class="mb-0 fw-bold">Income vs Expenses</h6></div>
                        <div class="card-body d-flex align-items-center justify-content-center">
                            <div style="max-height: 300px; width: 100%;">
                                <canvas id="chartIncomeExpenses"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="card shadow-sm h-100">
                        <div class="card-header bg-white py-2"><h6 class="mb-0 fw-bold">Balance Projection (12 Months)</h6></div>
                        <div class="card-body">
                            <div style="max-height: 300px; width: 100%;">
                                <canvas id="chartProjection"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-12 pb-4">
                    <div class="card shadow-sm">
                        <div class="card-header bg-white py-2"><h6 class="mb-0 fw-bold">Effort Rate Analysis</h6></div>
                        <div class="card-body">
                            <div style="height: 100px; width: 100%;">
                                <canvas id="chartEffortRate"></canvas>
                            </div>
                            <div class="mt-3 text-center small text-muted">
                                <i class="bi bi-info-circle me-1"></i> A healthy effort rate is typically below 40%.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Modals -->
<div class="modal fade" id="addEntryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="AddEntry" method="post">
                <input type="hidden" name="ScenarioId" value="@Model.Scenario.Id" />
                <div class="modal-header">
                    <h5 class="modal-title">Add Financial Entry</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label text-dark">Type</label>
                        <select name="TypeId" class="form-select" required>
                            @foreach (var type in Model.EntryTypes)
                            {
                                <option value="@type.Id">@type.Type</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-dark">Category</label>
                        <select name="CategoryId" class="form-select" required>
                            @foreach (var cat in Model.Categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-floating mb-3 text-dark">
                        <input name="Amount" type="number" step="0.01" class="form-control" placeholder="Amount" required />
                        <label>Amount ($)</label>
                    </div>
                    <div class="mb-3 text-dark">
                        <label class="form-label">Month of Entry</label>
                        <select name="Month" class="form-select" required>
                            <option value="1">January</option>
                            <option value="2">February</option>
                            <option value="3">March</option>
                            <option value="4">April</option>
                            <option value="5">May</option>
                            <option value="6">June</option>
                            <option value="7">July</option>
                            <option value="8">August</option>
                            <option value="9">September</option>
                            <option value="10">October</option>
                            <option value="11">November</option>
                            <option value="12">December</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input name="Recurrence" class="form-check-input" type="checkbox" id="flexSwitchCheckDefault" value="true">
                            <label class="form-check-label text-dark" for="flexSwitchCheckDefault">Is this a Recurring Monthly entry?</label>
                            <input name="Recurrence" type="hidden" value="false" />
                        </div>
                        <small class="text-muted">Recurring entries will be included in the monthly balance calculation.</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Entry</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="addObjectiveModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="AddObjective" method="post">
                <input type="hidden" name="ScenarioId" value="@Model.Scenario.Id" />
                <div class="modal-header">
                    <h5 class="modal-title">Add Savings Goal</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="form-floating mb-3 text-dark">
                        <input name="Description" type="text" class="form-control" placeholder="Description" required />
                        <label>Description (e.g., Buy a Car)</label>
                    </div>
                    <div class="form-floating mb-3 text-dark">
                        <input name="TargetValue" type="number" step="0.01" class="form-control" placeholder="Target Amount" required />
                        <label>Target Amount ($)</label>
                    </div>
                    <div class="form-floating mb-3 text-dark">
                        <input name="TargetMonths" type="number" min="1" class="form-control" placeholder="Months" required />
                        <label>Target Months (Timeframe)</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save Goal</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="creditSimModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="RunSimulation" method="post">
                <input type="hidden" name="scenarioId" value="@scenario.Id" />
                <div class="modal-header bg-info text-white">
                    <h5 class="modal-title">Credit Simulation</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small mb-4">Simulate how a loan would impact your monthly budget and effort rate.</p>
                    
                    <div class="form-floating mb-3 text-dark">
                        <input asp-for="LoanSimulation.Principal" type="number" step="0.01" class="form-control" placeholder="Principal" required />
                        <label asp-for="LoanSimulation.Principal">Loan Amount (Principal)</label>
                    </div>
                    
                    <div class="form-floating mb-3 text-dark">
                        <input asp-for="LoanSimulation.AnnualInterestRate" type="number" step="0.01" class="form-control" placeholder="Interest Rate" required />
                        <label asp-for="LoanSimulation.AnnualInterestRate">Annual Interest Rate (%)</label>
                    </div>
                    
                    <div class="form-floating mb-3 text-dark">
                        <input asp-for="LoanSimulation.TermMonths" type="number" min="1" class="form-control" placeholder="Term" required />
                        <label asp-for="LoanSimulation.TermMonths">Term (Months)</label>
                    </div>

                    <div class="alert alert-warning small">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        The monthly installment will be added as a virtual expense in this simulation.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-info text-white fw-bold">Run "What-If" Simulation</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Scenario Modal (US_C002) -->
<div class="modal fade" id="editScenarioModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="UpdateScenario" method="post">
                <input type="hidden" name="id" value="@Model.Scenario.Id" />
                <div class="modal-header">
                    <h5 class="modal-title">Edit Scenario</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="form-floating mb-3">
                        <input name="familyName" type="text" class="form-control" value="@Model.Scenario.FamilyName" required />
                        <label>Family Name</label>
                    </div>
                    <div class="form-floating mb-3">
                        <input name="initialBalance" type="number" step="0.01" class="form-control" value="@Model.Scenario.InitialBalance" required />
                        <label>Initial Balance ($)</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showTab(tabName) {
            if (tabName === 'tables') {
                document.getElementById('tabTables').style.display = 'block';
                document.getElementById('tabCharts').style.display = 'none';
                document.getElementById('btnTables').classList.add('active');
                document.getElementById('btnCharts').classList.remove('active');
            } else {
                document.getElementById('tabTables').style.display = 'none';
                document.getElementById('tabCharts').style.display = 'block';
                document.getElementById('btnTables').classList.remove('active');
                document.getElementById('btnCharts').classList.add('active');
                renderCharts();
            }
        }

        let chartsInitialized = false;
        function renderCharts() {
            if (chartsInitialized) return;
            @if (lastResult != null) {
                <text>
                // 1. Income vs Expenses Pie Chart
                new Chart(document.getElementById('chartIncomeExpenses'), {
                    type: 'doughnut',
                    data: {
                        labels: ['Income', 'Expenses'],
                        datasets: [{
                            data: [@lastResult.Summary.TotalMonthlyIncome, @lastResult.Summary.TotalMonthlyExpenses],
                            backgroundColor: ['#198754', '#dc3545'],
                            borderWidth: 0
                        }]
                    },
                    options: { maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
                });

                // 2. Projection Line Chart
                const initial = @scenario.InitialBalance;
                const monthlyBalance = @lastResult.Summary.MonthlyBalance;
                const labels = ['Now', '1m', '2m', '3m', '4m', '5m', '6m', '7m', '8m', '9m', '10m', '11m', '12m'];
                const dataPoints = [];
                for (let i = 0; i <= 12; i++) {
                    dataPoints.push(initial + (monthlyBalance * i));
                }

                new Chart(document.getElementById('chartProjection'), {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Projected Balance',
                            data: dataPoints,
                            borderColor: '#0d6efd',
                            backgroundColor: 'rgba(13, 110, 253, 0.1)',
                            fill: true,
                            tension: 0.3
                        }]
                    },
                    options: { 
                        maintainAspectRatio: false, 
                        scales: { y: { beginAtZero: false, ticks: { callback: value => '$' + value } } } 
                    }
                });

                // 3. Effort Rate Bar Chart
                new Chart(document.getElementById('chartEffortRate'), {
                    type: 'bar',
                    data: {
                        labels: ['Current Effort Rate'],
                        datasets: [{
                            label: 'Your Rate (%)',
                            data: [@lastResult.Summary.EffortRatePercentage],
                            backgroundColor: @(lastResult.Summary.EffortRatePercentage > 40 ? "'#dc3545'" : "'#198754'"),
                            barThickness: 30
                        }, {
                            label: 'Health Limit (40%)',
                            data: [40],
                            backgroundColor: '#ffc107',
                            barThickness: 30
                        }]
                    },
                    options: { 
                        indexAxis: 'y',
                        maintainAspectRatio: false,
                        scales: { x: { max: 100, ticks: { callback: v => v + '%' } } }
                    }
                });
                
                chartsInitialized = true;
                </text>
            }
        }
    </script>
}
