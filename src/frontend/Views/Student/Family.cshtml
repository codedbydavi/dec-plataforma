@model IEnumerable<Frontend.Models.Entities.Scenario>

@{
    ViewData["Title"] = "Cenários Familiares";
}

<div class="max-w-4xl mx-auto p-6">
    <div class="mb-6">
        <h1 class="text-3xl mb-2 font-bold">Cenários Familiares</h1>
        <p class="text-gray-500">
            Define o agregado familiar e os parâmetros financeiros para simulações
        </p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">@TempData["SuccessMessage"]</span>
        </div>
    }

    <!-- List of Scenarios -->
    <div class="grid md:grid-cols-2 gap-4 mb-8">
        @foreach (var scenario in Model)
        {
            <div class="bg-white rounded-xl border p-6 shadow-sm hover:border-primary transition-colors">
                <div class="flex items-center gap-2 mb-4">
                    <i data-lucide="home" class="w-5 h-5 text-primary"></i>
                    <h3 class="font-bold text-lg">@scenario.FamilyName</h3>
                </div>
                <p class="text-sm text-gray-500 mb-4">Saldo Inicial: €@scenario.InitialBalance.ToString("0.00")</p>
                <div class="flex gap-2">
                    <a asp-action="ScenarioDetails" asp-route-id="@scenario.Id" class="px-4 py-2 bg-primary text-white rounded-md text-sm font-medium hover:bg-primary/90 flex-1 text-center">
                        Gerir Cenário
                    </a>
                    <button type="button" data-modal-target="deleteScenarioModal-@scenario.Id" class="px-3 py-2 bg-red-50 text-red-600 rounded-md hover:bg-red-100 transition-colors" title="Apagar Cenário">
                        <i data-lucide="trash-2" class="w-4 h-4"></i>
                    </button>
                </div>
            </div>

            <!-- Modal Delete Scenario -->
            <div id="deleteScenarioModal-@scenario.Id" class="hidden fixed inset-0 bg-black/50 z-[100] flex items-center justify-center">
                <div class="bg-white rounded-xl shadow-xl w-full max-w-sm overflow-hidden">
                    <form asp-action="DeleteScenario" asp-route-id="@scenario.Id" method="post">
                        <div class="p-6 text-center">
                            <div class="w-12 h-12 rounded-full bg-red-100 text-red-600 flex items-center justify-center mx-auto mb-4">
                                <i data-lucide="alert-triangle" class="w-6 h-6"></i>
                            </div>
                            <h3 class="text-lg font-bold mb-2">Apagar Cenário</h3>
                            <p class="text-gray-500 mb-6">Tem a certeza que deseja apagar o cenário <strong>@scenario.FamilyName</strong>? Esta ação apagará também todos os lançamentos financeiros deste cenário e não pode ser desfeita.</p>
                            <div class="flex gap-3 justify-center">
                                <button type="button" onclick="document.getElementById('deleteScenarioModal-@scenario.Id').classList.add('hidden')" class="px-4 py-2 border rounded-md hover:bg-gray-100 font-medium">Cancelar</button>
                                <button type="submit" class="px-4 py-2 bg-red-600 text-white rounded-md hover:bg-red-700 font-medium">Sim, apagar</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        }

        <div class="bg-gray-50 rounded-xl border-2 border-dashed border-gray-300 p-6 flex flex-col items-center justify-center text-center hover:bg-gray-100 transition-colors cursor-pointer" data-modal-target="createScenarioModal">
            <i data-lucide="plus-circle" class="w-8 h-8 text-gray-400 mb-2"></i>
            <h3 class="font-bold text-gray-600">Novo Cenário</h3>
            <p class="text-sm text-gray-500">Adicionar família</p>
        </div>
    </div>
</div>

<!-- Modal Create Scenario -->
<div id="createScenarioModal" class="hidden fixed inset-0 bg-black/50 z-[100] flex items-center justify-center">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-lg overflow-hidden">
        <form asp-action="CreateScenario" method="post">
            <div class="px-6 py-4 border-b">
                <h3 class="text-lg font-bold">Criar Cenário Familiar</h3>
            </div>
            
            <div class="p-6 space-y-4">
                <!-- Presets Section -->
                <div>
                    <label class="block text-sm font-medium mb-2 text-gray-700">Cenários Sugeridos</label>
                    <div class="grid grid-cols-2 gap-2">
                        <button type="button" onclick="fillPreset('Estudante Deslocado', 800)" class="text-left px-3 py-2 border border-gray-200 rounded-md hover:bg-gray-50 hover:border-primary transition-colors">
                            <p class="text-sm font-bold text-primary">Estudante Deslocado</p>
                            <p class="text-xs text-gray-500">Saldo: €800</p>
                        </button>
                        <button type="button" onclick="fillPreset('Família Monoparental', 1500)" class="text-left px-3 py-2 border border-gray-200 rounded-md hover:bg-gray-50 hover:border-primary transition-colors">
                            <p class="text-sm font-bold text-primary">Família Monoparental</p>
                            <p class="text-xs text-gray-500">Saldo: €1.500</p>
                        </button>
                        <button type="button" onclick="fillPreset('Família 2 Filhos', 2500)" class="text-left px-3 py-2 border border-gray-200 rounded-md hover:bg-gray-50 hover:border-primary transition-colors">
                            <p class="text-sm font-bold text-primary">Família 2 Filhos</p>
                            <p class="text-xs text-gray-500">Saldo: €2.500</p>
                        </button>
                        <button type="button" onclick="fillPreset('Casal Jovem', 2000)" class="text-left px-3 py-2 border border-gray-200 rounded-md hover:bg-gray-50 hover:border-primary transition-colors">
                            <p class="text-sm font-bold text-primary">Casal Jovem</p>
                            <p class="text-xs text-gray-500">Saldo: €2.000</p>
                        </button>
                    </div>
                </div>
                
                <div class="border-t pt-4">
                    <label class="block text-sm font-medium mb-1">Nome da Família</label>
                    <input id="familyNameInput" name="FamilyName" type="text" class="w-full border rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-primary/50" required />
                </div>
                <div>
                    <label class="block text-sm font-medium mb-1">Saldo Inicial (€)</label>
                    <input id="initialBalanceInput" name="InitialBalance" type="number" step="0.01" class="w-full border rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-primary/50" required />
                </div>
            </div>
            <div class="px-6 py-4 bg-gray-50 flex justify-end gap-3">
                <button type="button" onclick="document.getElementById('createScenarioModal').classList.add('hidden')" class="px-4 py-2 border rounded-md hover:bg-gray-100 font-medium">Cancelar</button>
                <button type="submit" class="px-4 py-2 bg-primary text-white rounded-md hover:bg-primary/90 font-medium">Criar Cenário</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function fillPreset(name, balance) {
            document.getElementById('familyNameInput').value = name;
            document.getElementById('initialBalanceInput').value = balance;
        }

        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('[data-modal-target]').forEach(btn => {
                btn.addEventListener('click', () => {
                    const target = document.getElementById(btn.getAttribute('data-modal-target'));
                    if (target) target.classList.remove('hidden');
                });
            });
        });
    </script>
}
