@model Frontend.Models.DTOs.TurmaDetalhesDto

@{
    ViewData["Title"] = $"Class: {Model.Nome}";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Dashboard">Dashboard</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Nome</li>
      </ol>
    </nav>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h2 class="card-title">@Model.Nome</h2>
                    <p class="text-muted">Manage students and class progress.</p>
                </div>
                <div class="col-md-4 text-end">
                    <div class="p-3 bg-light border rounded text-center">
                        <small class="text-uppercase d-block text-muted mb-1">Join Code</small>
                        <h3 class="mb-0 text-primary fw-bold">@Model.Codigo_Adesao</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <h3>Enrolled Students (@Model.Alunos.Count)</h3>
    <div class="table-responsive bg-white rounded shadow-sm">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Username</th>
                    <th>Email</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Alunos.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center py-4 text-muted">
                            No students have joined this class yet using the code.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var aluno in Model.Alunos)
                    {
                        <tr>
                            <td><strong>@aluno.Name</strong></td>
                            <td>@aluno.Username</td>
                            <td>@aluno.Email</td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-info">View Progress</button>
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
