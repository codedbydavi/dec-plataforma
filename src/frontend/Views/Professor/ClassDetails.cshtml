@model Frontend.Models.Entities.Classroom

@{
    ViewData["Title"] = $"Class: {Model.Name}";
}

<div class="container mt-4 page-fade-in">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Dashboard">Dashboard</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
      </ol>
    </nav>

    <div class="card shadow-sm mb-4 border-primary border-top border-4">
        <div class="card-body">
            <div class="row align-items-center">
                <div class="col">
                    <h2 class="fw-bold text-dark mb-0">@Model.Name</h2>
                    <p class="text-muted mb-0">Manage students and evaluate their financial scenarios.</p>
                </div>
                <div class="col-auto text-end">
                    <div class="bg-light p-3 rounded-3 border">
                        <small class="text-uppercase text-muted fw-bold d-block mb-1" style="font-size: 0.7rem;">Class Join Code</small>
                        <h3 class="mb-0 text-primary fw-bold" style="letter-spacing: 2px;">@Model.MemberCode</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-9">
            <h3 class="mb-3 fw-bold"><i class="bi bi-people me-2"></i>Enrolled Students (@Model.Enrollments.Count)</h3>
            <div class="table-responsive bg-white rounded shadow-sm border mb-4">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="py-3 px-4">Student Name</th>
                            <th class="py-3">Current Balance</th>
                            <th class="py-3 text-center">Submissions</th>
                            <th class="text-end py-3 px-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Enrollments.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <i class="bi bi-people fs-1 d-block mb-3 opacity-25"></i>
                                    <p class="mb-0">No students have joined this class yet.</p>
                                    <small>Share the code <strong>@Model.MemberCode</strong> with your students.</small>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var enrollment in Model.Enrollments)
                            {
                                var student = enrollment.Student;
                                var latestScenario = student?.Scenarios.OrderByDescending(s => s.Id).FirstOrDefault();
                                <tr>
                                    <td class="px-4">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-primary text-white rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                                @(student?.FullName?[0].ToString() ?? "?")
                                            </div>
                                            <div>
                                                <div class="fw-bold">@student?.FullName</div>
                                                <small class="text-muted">@student?.Email</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        @if (latestScenario != null)
                                        {
                                            <span class="fw-semibold">@latestScenario.InitialBalance.ToString("C")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">No scenario created</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-secondary rounded-pill">@(latestScenario?.Histories.Count ?? 0)</span>
                                    </td>
                                    <td class="text-end px-4">
                                        @if (latestScenario?.Histories.Any() == true)
                                        {
                                            <button class="btn btn-sm btn-success rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#evaluateModal-@enrollment.Id">
                                                Evaluate
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-secondary rounded-pill px-3" disabled>No Submissions</button>
                                        }
                                    </td>
                                </tr>

                                <!-- Evaluation Modal -->
                                @if (latestScenario?.Histories.Any() == true)
                                {
                                    var latestHistory = latestScenario.Histories.OrderByDescending(h => h.Id).First();
                                    <div class="modal fade" id="evaluateModal-@enrollment.Id" tabindex="-1">
                                        <div class="modal-dialog modal-lg">
                                            <div class="modal-content">
                                                <form asp-action="Evaluate" method="post">
                                                    <input type="hidden" name="historyId" value="@latestHistory.Id" />
                                                    <div class="modal-header">
                                                        <h5 class="modal-title fw-bold">Evaluate Submission: @student?.FullName</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                    </div>
                                                    <div class="modal-body">
                                                        <div class="row mb-4 text-dark">
                                                            <div class="col-md-6">
                                                                <label class="text-muted small">Final Balance</label>
                                                                <h4 class="fw-bold">@latestHistory.FinalBalance.ToString("C")</h4>
                                                            </div>
                                                            <div class="col-md-6">
                                                                <label class="text-muted small">Effort Rate</label>
                                                                <h4 class="fw-bold">@latestHistory.EffortRate.ToString("F1")%</h4>
                                                            </div>
                                                        </div>
                                                        <div class="mb-3 text-dark">
                                                            <label class="form-label">Score (0-20)</label>
                                                            <input name="score" type="number" step="0.1" min="0" max="20" class="form-control" placeholder="18.5" required />
                                                        </div>
                                                        <div class="mb-3 text-dark">
                                                            <label class="form-label">Feedback</label>
                                                            <textarea name="feedback" class="form-control" rows="3" placeholder="Excellent financial planning..."></textarea>
                                                        </div>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                                                        <button type="submit" class="btn btn-success px-4">Submit Evaluation</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
        
        <div class="col-lg-3">
            <h3 class="mb-3 fw-bold"><i class="bi bi-flag-fill me-2 text-info"></i>Challenges</h3>
            <div class="list-group shadow-sm border-0 mb-4">
                @if (ViewBag.AssignedChallenges != null)
                {
                    @foreach (var assignment in (IEnumerable<Frontend.Models.Entities.ChallengeAssignment>)ViewBag.AssignedChallenges)
                    {
                        <div class="list-group-item py-3 border-0 border-start border-4 border-info mb-2 rounded shadow-sm bg-white">
                            <h6 class="fw-bold mb-1">@assignment.Challenge?.Name</h6>
                            <p class="small text-muted mb-0">Assigned: @assignment.AssignedAt.ToString("d")</p>
                        </div>
                    }
                }
                @if (ViewBag.AssignedChallenges == null || !((IEnumerable<Frontend.Models.Entities.ChallengeAssignment>)ViewBag.AssignedChallenges).Any())
                {
                    <div class="card card-body text-center py-4 bg-light border-dashed">
                        <small class="text-muted">No challenges assigned.</small>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
