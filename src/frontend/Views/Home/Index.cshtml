@{
    ViewData["Title"] = "Welcome";
}

<div class="flex-grow-1 d-flex flex-column" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
    <!-- Center Content -->
    <div class="container d-flex flex-column justify-content-center align-items-center text-center text-white flex-grow-1 px-4">
        
        <div class="mb-4 animate-fade-in">
            <div class="bg-white bg-opacity-10 rounded-circle p-4 d-inline-flex align-items-center justify-content-center mb-3 shadow-lg border border-white border-opacity-25">
                <i class="bi bi-wallet2 display-3"></i>
            </div>
            <h1 class="display-3 fw-bold mb-2">DEC - Money at Home</h1>
            <p class="lead fs-4 opacity-75 max-width-600 mx-auto">
                Real-world financial literacy through smart simulation.
            </p>
        </div>

        <div class="d-flex flex-wrap justify-content-center gap-3 animate-slide-up">
            @if (User.Identity?.IsAuthenticated != true)
            {
                <a asp-controller="Auth" asp-action="Login" class="btn btn-light btn-lg px-5 py-3 fw-bold text-primary rounded-pill shadow-lg hover-scale">
                    Get Started <i class="bi bi-arrow-right ms-2"></i>
                </a>
                <a asp-controller="Auth" asp-action="Register" class="btn btn-outline-light btn-lg px-5 py-3 fw-bold rounded-pill hover-scale">
                    Register
                </a>
            }
            else
            {
                <a asp-controller="Professor" asp-action="Dashboard" class="btn btn-light btn-lg px-5 py-3 fw-bold text-primary rounded-pill shadow-lg hover-scale">
                    Go to Dashboard <i class="bi bi-speedometer2 ms-2"></i>
                </a>
            }
        </div>

        <!-- Quick Features (Condensed) -->
        <div class="row w-100 mt-5 pt-4 border-top border-white border-opacity-10 d-none d-md-flex animate-fade-in-slow">
            <div class="col">
                <i class="bi bi-bank fs-4 mb-2 d-block"></i>
                <span class="small fw-semibold opacity-75">Family Scenarios</span>
            </div>
            <div class="col border-start border-white border-opacity-10">
                <i class="bi bi-graph-up-arrow fs-4 mb-2 d-block"></i>
                <span class="small fw-semibold opacity-75">Real Simulations</span>
            </div>
            <div class="col border-start border-white border-opacity-10">
                <i class="bi bi-mortarboard fs-4 mb-2 d-block"></i>
                <span class="small fw-semibold opacity-75">Education First</span>
            </div>
        </div>
    </div>
</div>

<style>
    .max-width-600 { max-width: 600px; }
    
    .hover-scale { transition: transform 0.2s ease-in-out; }
    .hover-scale:hover { transform: scale(1.05); }

    /* Animations */
    .animate-fade-in { animation: fadeIn 0.8s ease-out; }
    .animate-slide-up { animation: slideUp 0.8s ease-out 0.2s both; }
    .animate-fade-in-slow { animation: fadeIn 1.2s ease-out 0.5s both; }

    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Handle very small mobile screens */
    @@media (max-height: 600px) {
        h1 { font-size: 2rem !important; }
        .display-3 { font-size: 2.5rem !important; }
        .mb-4 { margin-bottom: 1rem !important; }
        .mt-5 { margin-top: 1rem !important; }
    }
</style>
