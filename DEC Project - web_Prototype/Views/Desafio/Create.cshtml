@model DEC.Models.Desafio

@{
    ViewData["Title"] = "Criar Desafio";
}

<div class="container">
    <h1 class="mb-3">Criar Novo Desafio</h1>

    <div class="card">
        <form asp-action="Create" method="post">
            <div class="form-group">
                <label class="form-label">Título do Desafio *</label>
                <input type="text" asp-for="Titulo" class="form-control" placeholder="Ex: Orçamento Familiar Básico" required />
            </div>

            <div class="form-group">
                <label class="form-label">Descrição *</label>
                <textarea asp-for="Descricao" class="form-control" rows="4" placeholder="Descreva o desafio e o que os alunos devem fazer..." required></textarea>
            </div>

            <div class="form-group">
                <label class="form-label">Objetivo de Aprendizagem</label>
                <textarea asp-for="ObjetivoAprendizagem" class="form-control" rows="3" placeholder="Que competências ou conhecimentos os alunos vão desenvolver?"></textarea>
            </div>

            <div class="grid-2">
                <div class="form-group">
                    <label class="form-label">Nível de Dificuldade *</label>
                    <select asp-for="Nivel" class="form-select" required>
                        <option value="0">Fácil</option>
                        <option value="1">Médio</option>
                        <option value="2">Difícil</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">Pontos *</label>
                    <input type="number" asp-for="Pontos" class="form-control" min="1" value="50" required />
                    <small style="color: #666;">Fácil: 25-50 | Médio: 75-100 | Difícil: 125-200</small>
                </div>
            </div>

            <div class="form-group">
                <label class="form-check-label">
                    <input type="checkbox" asp-for="Ativo" checked /> Desafio Ativo
                </label>
                <br>
                <small style="color: #666;">Desafios inativos não aparecem para os alunos</small>
            </div>

            <div class="flex gap-1 mt-3">
                <button type="submit" class="btn btn-primary">Criar Desafio</button>
                <a class="btn btn-secondary" asp-action="Index">Cancelar</a>
            </div>
        </form>
    </div>

    <div class="card" style="background: #f8f9fa;">
        <h3 style="margin-bottom: 1rem; color: var(--istec-blue);">Sugestões de Desafios</h3>

        <div style="margin-bottom: 1.5rem;">
            <h4 style="font-size: 1rem; margin-bottom: 0.5rem;">Nível Fácil (25-50 pontos)</h4>
            <ul style="color: #666;">
                <li>Criar uma família e registar todas as receitas e despesas mensais</li>
                <li>Identificar e categorizar 10 diferentes tipos de despesas</li>
                <li>Calcular a taxa de esforço de uma família</li>
            </ul>
        </div>

        <div style="margin-bottom: 1.5rem;">
            <h4 style="font-size: 1rem; margin-bottom: 0.5rem;">Nível Médio (75-100 pontos)</h4>
            <ul style="color: #666;">
                <li>Ajustar o orçamento para atingir uma taxa de esforço ideal (&lt;35%)</li>
                <li>Criar um plano de poupança com objetivo específico</li>
                <li>Simular o impacto de um aumento de 10% nos rendimentos</li>
            </ul>
        </div>

        <div style="margin-bottom: 1.5rem;">
            <h4 style="font-size: 1rem; margin-bottom: 0.5rem;">Nível Difícil (125-200 pontos)</h4>
            <ul style="color: #666;">
                <li>Simular a amortização de um crédito habitação e otimizar o prazo</li>
                <li>Criar um plano financeiro de 5 anos considerando inflação</li>
                <li>Gerir 3 famílias diferentes e comparar estratégias de poupança</li>
            </ul>
        </div>
    </div>
</div>
