@model DEC.Models.Familia

@{
    ViewData["Title"] = "Editar Família";
}

<div class="container">
    <h1 class="mb-3">Editar @Model.Nome</h1>

    <div class="card">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />

            <h3 style="margin-bottom: 1.5rem; color: var(--istec-blue);">Informações Básicas</h3>

            <div class="form-group">
                <label class="form-label">Nome da Família *</label>
                <input type="text" asp-for="Nome" class="form-control" required />
            </div>

            <div class="form-group">
                <label class="form-label">Descrição</label>
                <textarea asp-for="Descricao" class="form-control" rows="3"></textarea>
            </div>

            <div class="grid-2">
                <div class="form-group">
                    <label class="form-label">Número de Adultos *</label>
                    <input type="number" asp-for="NumeroAdultos" class="form-control" min="1" required />
                </div>

                <div class="form-group">
                    <label class="form-label">Número de Crianças</label>
                    <input type="number" asp-for="NumeroCriancas" class="form-control" min="0" />
                </div>
            </div>

            <div class="form-group">
                <label class="form-check-label">
                    <input type="checkbox" asp-for="Ativa" /> Família Ativa
                </label>
            </div>

            <div class="flex gap-1 mt-3">
                <button type="submit" class="btn btn-primary">Guardar Alterações</button>
                <a class="btn btn-secondary" asp-action="Details" asp-route-id="@Model.Id">Cancelar</a>
            </div>
        </form>
    </div>
</div>
