@{
    ViewData["Title"] = "Student Dashboard";
}

<div class="container mt-4 page-fade-in">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>My Dashboard</h1>
    </div>

    <div class="row">
        <!-- Classes Section -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">My Classes</h5>
                    <button class="btn btn-sm btn-light" data-bs-toggle="modal" data-bs-target="#joinClassModal">Join Class</button>
                </div>
                <div class="card-body">
                    @if (ViewBag.Classes == null || ((IEnumerable<dynamic>)ViewBag.Classes).Count() == 0)
                    {
                        <p class="text-muted">You haven't joined any classes yet.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var classGroup in ViewBag.Classes)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>@classGroup.Name</strong>
                                        <br/>
                                        <small class="text-muted">Teacher: @classGroup.Teacher?.FullName</small>
                                    </div>
                                    <span class="badge bg-secondary rounded-pill">Enrolled</span>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>

        <!-- Scenarios Section -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">My Scenarios</h5>
                    <button class="btn btn-sm btn-light" data-bs-toggle="modal" data-bs-target="#createScenarioModal">New Scenario</button>
                </div>
                <div class="card-body">
                    @if (ViewBag.Scenarios == null || ((IEnumerable<dynamic>)ViewBag.Scenarios).Count() == 0)
                    {
                        <p class="text-muted">You haven't created any scenarios yet.</p>
                    }
                    else
                    {
                        <div class="row">
                            @foreach (var scenario in ViewBag.Scenarios)
                            {
                                <div class="col-12 mb-3">
                                    <div class="card border-info">
                                        <div class="card-body">
                                            <h6 class="card-title">@scenario.FamilyName Family</h6>
                                            <p class="card-text mb-1"><small class="text-muted">Initial Balance: $@scenario.InitialBalance</small></p>
                                            <a asp-action="ScenarioDetails" asp-route-id="@scenario.Id" class="btn btn-sm btn-outline-info w-100">Manage Financials</a>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Join Class Modal -->
<div class="modal fade" id="joinClassModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="JoinClass" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">Join a Class</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="form-floating mb-3">
                        <input name="JoinCode" type="text" class="form-control" id="joinCodeInput" placeholder="Join Code" required />
                        <label for="joinCodeInput">Class Code (e.g., 123456)</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Join Class</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Create Scenario Modal -->
<div class="modal fade" id="createScenarioModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="CreateScenario" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">Create New Scenario</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="form-floating mb-3">
                        <input name="FamilyName" type="text" class="form-control" id="familyNameInput" placeholder="Family Name" required />
                        <label for="familyNameInput">Family Name</label>
                    </div>
                    <div class="form-floating mb-3">
                        <input name="InitialBalance" type="number" step="0.01" class="form-control" id="initialBalanceInput" placeholder="Initial Balance" required />
                        <label for="initialBalanceInput">Initial Balance ($)</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Create Scenario</button>
                </div>
            </form>
        </div>
    </div>
</div>
