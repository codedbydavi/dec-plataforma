@model Frontend.Models.Entities.Classroom

@{
    ViewData["Title"] = $"Class: {Model.Name}";
}

<div class="container mt-4 page-fade-in">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Dashboard">Dashboard</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
      </ol>
    </nav>

    <div class="card shadow-sm mb-4 border-primary border-top border-4">
        <div class="card-body">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h2 class="card-title fw-bold text-dark">@Model.Name</h2>
                    <p class="text-muted mb-0">Manage students and class progress.</p>
                </div>
                <div class="col-md-4 text-end mt-3 mt-md-0">
                    <div class="p-3 bg-light border rounded text-center">
                        <small class="text-uppercase d-block text-muted mb-1 fw-bold">Join Code</small>
                        <h3 class="mb-0 text-primary fw-bold" style="letter-spacing: 2px;">@Model.MemberCode</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <h3 class="mb-3">Enrolled Students (@Model.Enrollments.Count)</h3>
    <div class="table-responsive bg-white rounded shadow-sm border">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="py-3 px-4">Name</th>
                    <th class="py-3">Username</th>
                    <th class="py-3">Email</th>
                    <th class="text-end py-3 px-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Enrollments.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">
                            <i class="bi bi-people fs-1 d-block mb-3 opacity-25"></i>
                            <p class="mb-0">No students have joined this class yet.</p>
                            <small>Share the code <strong>@Model.MemberCode</strong> with your students.</small>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var enrollment in Model.Enrollments)
                    {
                        <tr>
                            <td class="px-4"><strong>@enrollment.Student!.FullName</strong></td>
                            <td><span class="text-muted">@enrollment.Student.UserName</span></td>
                            <td>@enrollment.Student.Email</td>
                            <td class="text-end px-4">
                                <button class="btn btn-sm btn-outline-info rounded-pill px-3 me-1">View Progress</button>
                                <button class="btn btn-sm btn-outline-danger rounded-circle"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
