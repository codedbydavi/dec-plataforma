@{
    ViewData["Title"] = "Welcome to DEC";
}

<div class="flex-grow-1 d-flex flex-column">
    <!-- Hero Section: Compact and Responsive -->
    <div class="hero-section text-white flex-grow-1 d-flex align-items-center shadow-sm" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 40vh;">
        <div class="container py-4 text-center">
            <h1 class="display-4 fw-bold mb-2">Master Your Money</h1>
            <p class="lead mb-4 opacity-75">Empowering students with real-world financial literacy through simulation.</p>
            @if (User.Identity?.IsAuthenticated != true)
            {
                <div class="d-flex justify-content-center gap-3">
                    <a asp-controller="Auth" asp-action="Login" class="btn btn-light btn-lg px-4 py-2 fw-bold text-primary rounded-pill shadow-sm">Get Started</a>
                </div>
            }
            else
            {
                <div class="d-flex justify-content-center gap-3">
                    <a asp-controller="Professor" asp-action="Dashboard" class="btn btn-light btn-lg px-4 py-2 fw-bold text-primary rounded-pill shadow-sm">Dashboard</a>
                </div>
            }
        </div>
    </div>

    <!-- Features Section: Scalable Grid -->
    <div class="container py-4">
        <div class="row g-4 row-cols-1 row-cols-md-3">
            <div class="col text-center">
                <div class="feature-icon d-inline-flex align-items-center justify-content-center bg-primary bg-gradient text-white fs-3 mb-2 rounded-circle shadow" style="width: 3.5rem; height: 3.5rem;">
                    <i class="bi bi-bank"></i>
                </div>
                <h3 class="h5 fw-bold text-dark">Family Scenarios</h3>
                <p class="small text-muted mb-0">Manage budgets and track monthly income and expenses.</p>
            </div>
            <div class="col text-center">
                <div class="feature-icon d-inline-flex align-items-center justify-content-center bg-success bg-gradient text-white fs-3 mb-2 rounded-circle shadow" style="width: 3.5rem; height: 3.5rem;">
                    <i class="bi bi-graph-up-arrow"></i>
                </div>
                <h3 class="h5 fw-bold text-dark">Real Simulations</h3>
                <p class="small text-muted mb-0">Run complex simulations using our advanced calculation engine.</p>
            </div>
            <div class="col text-center">
                <div class="feature-icon d-inline-flex align-items-center justify-content-center bg-info bg-gradient text-white fs-3 mb-2 rounded-circle shadow" style="width: 3.5rem; height: 3.5rem;">
                    <i class="bi bi-mortarboard"></i>
                </div>
                <h3 class="h5 fw-bold text-dark">Educational Goals</h3>
                <p class="small text-muted mb-0">Join classes and complete challenges to build your future.</p>
            </div>
        </div>
    </div>

    <!-- Bottom Promo: Clean & Focused -->
    <div class="bg-white py-4 mt-auto border-top">
        <div class="container">
            <div class="row align-items-center justify-content-center">
                <div class="col-lg-8 text-center">
                    <h4 class="fw-bold text-dark mb-2">Designed for the Next Generation</h4>
                    <p class="text-muted small mb-0">DEC provides a hands-on experience for secondary school students to learn about financial planning and secure saving habits.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Ensure no scroll on the main landing container for desktop */
    @@media (min-width: 992px) {
        body { overflow: hidden; }
        main { height: calc(100vh - 120px); } /* Approx header + footer height */
    }
</style>
