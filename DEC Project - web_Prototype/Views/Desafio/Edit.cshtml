@model DEC.Models.Desafio

@{
    ViewData["Title"] = "Editar Desafio";
}

<div class="container">
    <h1 class="mb-3">Editar Desafio</h1>

    <div class="card">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CriadoPorId" />
            <input type="hidden" asp-for="DataCriacao" />

            <div class="form-group">
                <label class="form-label">Título do Desafio *</label>
                <input type="text" asp-for="Titulo" class="form-control" required />
            </div>

            <div class="form-group">
                <label class="form-label">Descrição *</label>
                <textarea asp-for="Descricao" class="form-control" rows="4" required></textarea>
            </div>

            <div class="form-group">
                <label class="form-label">Objetivo de Aprendizagem</label>
                <textarea asp-for="ObjetivoAprendizagem" class="form-control" rows="3"></textarea>
            </div>

            <div class="grid-2">
                <div class="form-group">
                    <label class="form-label">Nível de Dificuldade *</label>
                    <select asp-for="Nivel" class="form-select" required>
                        <option value="0">Fácil</option>
                        <option value="1">Médio</option>
                        <option value="2">Difícil</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">Pontos *</label>
                    <input type="number" asp-for="Pontos" class="form-control" min="1" required />
                </div>
            </div>

            <div class="form-group">
                <label class="form-check-label">
                    <input type="checkbox" asp-for="Ativo" /> Desafio Ativo
                </label>
            </div>

            <div class="flex gap-1 mt-3">
                <button type="submit" class="btn btn-primary">Guardar Alterações</button>
                <a class="btn btn-secondary" asp-action="Index">Cancelar</a>
            </div>
        </form>
    </div>
</div>
