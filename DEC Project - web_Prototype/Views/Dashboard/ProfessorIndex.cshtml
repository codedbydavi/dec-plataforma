@{
    ViewData["Title"] = "Dashboard do Professor";
    var user = ViewBag.User as DEC.Models.User;
    var stats = ViewBag.Stats as Dictionary<string, object>;
    var desafios = ViewBag.Desafios as List<DEC.Models.Desafio>;
    var alunos = ViewBag.Alunos as List<DEC.Models.User>;
}

<div class="container">
    <h1 class="mb-3">Dashboard do Professor - @user.Nome</h1>

    <div class="dashboard-grid">
        <div class="stat-card">
            <div class="stat-label">Total de Alunos</div>
            <div class="stat-value">@stats["totalAlunos"]</div>
        </div>

        <div class="stat-card">
            <div class="stat-label">Desafios Criados</div>
            <div class="stat-value">@stats["totalDesafiosCriados"]</div>
        </div>

        <div class="stat-card">
            <div class="stat-label">Famílias Criadas</div>
            <div class="stat-value">@stats["totalFamilias"]</div>
        </div>
    </div>

    <div class="card">
        <div class="card-header flex justify-between align-center">
            <h2 class="card-title">Gestão de Desafios</h2>
            <a class="btn btn-primary" asp-controller="Desafio" asp-action="Create">+ Novo Desafio</a>
        </div>

        @if (desafios != null && desafios.Any())
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>Título</th>
                        <th>Nível</th>
                        <th>Pontos</th>
                        <th>Estado</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var desafio in desafios.Take(5))
                    {
                        var nivelClass = desafio.Nivel == DEC.Models.NivelDificuldade.Facil ? "nivel-facil" :
                                       desafio.Nivel == DEC.Models.NivelDificuldade.Medio ? "nivel-medio" : "nivel-dificil";

                        <tr>
                            <td>@desafio.Titulo</td>
                            <td><span class="desafio-nivel @nivelClass">@desafio.Nivel</span></td>
                            <td>@desafio.Pontos</td>
                            <td>
                                @if (desafio.Ativo)
                                {
                                    <span class="badge badge-success">Ativo</span>
                                }
                                else
                                {
                                    <span class="badge badge-danger">Inativo</span>
                                }
                            </td>
                            <td>
                                <a class="btn btn-primary btn-small" asp-controller="Desafio" asp-action="Edit" asp-route-id="@desafio.Id">Editar</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="text-center mt-2">
                <a class="btn btn-secondary" asp-controller="Desafio" asp-action="Index">Ver Todos os Desafios</a>
            </div>
        }
        else
        {
            <p style="text-align: center; padding: 2rem; color: #666;">
                Ainda não criaste nenhum desafio. <a asp-controller="Desafio" asp-action="Create">Criar o primeiro desafio</a>
            </p>
        }
    </div>

    <div class="card">
        <div class="card-header">
            <h2 class="card-title">Alunos Registados</h2>
        </div>

        @if (alunos != null && alunos.Any())
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Email</th>
                        <th>Turma</th>
                        <th>Data de Registo</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var aluno in alunos.Take(10))
                    {
                        <tr>
                            <td>@aluno.Nome</td>
                            <td>@aluno.Email</td>
                            <td>@(aluno.Turma ?? "N/A")</td>
                            <td>@aluno.DataCriacao.ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p style="text-align: center; padding: 2rem; color: #666;">Ainda não há alunos registados</p>
        }
    </div>
</div>
