@model IEnumerable<Frontend.Models.DTOs.TurmaDto>

@{
    ViewData["Title"] = "Dashboard do Professor";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>As Minhas Turmas</h1>
        <button class="btn btn-primary">Criar Nova Turma</button>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Ainda não criou nenhuma turma. Comece por criar uma para convidar os seus alunos.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var turma in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h5 class="card-title">@turma.Nome</h5>
                            <h6 class="card-subtitle mb-2 text-muted">Código: <span class="badge bg-dark">@turma.Codigo_Adesao</span></h6>
                            <p class="card-text">
                                <i class="bi bi-people-fill"></i> @turma.Aluno_Count Alunos Inscritos
                            </p>
                            <p class="card-text text-muted small">
                                Criada em: @turma.Data_Criacao.ToString("dd/MM/yyyy")
                            </p>
                        </div>
                        <div class="card-footer bg-transparent">
                            <a asp-action="TurmaDetalhes" asp-route-id="@turma.Id" class="btn btn-outline-primary btn-sm w-100">Ver Detalhes / Alunos</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
