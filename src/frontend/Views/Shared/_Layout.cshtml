<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DEC – Dinheiro em Casa</title>
    
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    <script src="https:
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: 'var(--primary)',
                        'primary-foreground': 'var(--primary-foreground)',
                        secondary: 'var(--secondary)',
                        'secondary-foreground': 'var(--secondary-foreground)',
                        background: 'var(--background)',
                        foreground: 'var(--foreground)',
                        card: 'var(--card)',
                        'card-foreground': 'var(--card-foreground)',
                        popover: 'var(--popover)',
                        'popover-foreground': 'var(--popover-foreground)',
                        muted: 'var(--muted)',
                        'muted-foreground': 'var(--muted-foreground)',
                        accent: 'var(--accent)',
                        'accent-foreground': 'var(--accent-foreground)',
                        destructive: 'var(--destructive)',
                        'destructive-foreground': 'var(--destructive-foreground)',
                        border: 'var(--border)',
                        input: 'var(--input)',
                        'input-background': 'var(--input-background)',
                        'switch-background': 'var(--switch-background)',
                        ring: 'var(--ring)',
                    },
                    borderRadius: {
                        lg: 'var(--radius)',
                        md: 'calc(var(--radius) - 2px)',
                        sm: 'calc(var(--radius) - 4px)',
                    },
                }
            }
        }
    </script>
    <style>
        [data-lucide] {
            width: 1rem;
            height: 1rem;
        }
        .lucide-lg {
            width: 1.5rem;
            height: 1.5rem;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="min-h-screen bg-gray-50 font-sans">
    @{
        var headerVariant = ViewData["HeaderVariant"] as string ?? "dark";
        var isLight = headerVariant == "light";
        var headerClass = isLight ? "bg-primary text-white" : "bg-white border-b";
        var logo = isLight ? "/images/0adf42d423b7a187f0e52c3f8865e6194626553e.png" : "/images/15b23ae75b11299058584f1907ef93163ec08d27.png";
        var titleClass = isLight ? "text-white" : "text-primary";
        var btnGhostClass = isLight ? "text-white hover:bg-white/10" : "text-foreground hover:bg-gray-100";
    }

    <header class="@headerClass py-4 px-6 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto flex items-center justify-between">
            <a asp-controller="Home" asp-action="Index" class="flex items-center gap-3">
                <img src="@logo" alt="ISTEC" class="h-10" />
                <div class="border-l border-current/20 pl-3">
                    <h1 class="text-xl font-bold @titleClass">
                        DEC – Dinheiro em Casa
                    </h1>
                </div>
            </a>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <nav class="hidden md:flex items-center gap-2">
                    @if (User.IsInRole("Student"))
                    {
                        <a asp-controller="Student" asp-action="Dashboard" class="flex items-center gap-2 px-3 py-2 rounded-md text-sm font-medium @btnGhostClass">
                            <i data-lucide="home"></i> Dashboard
                        </a>
                        <a asp-controller="Student" asp-action="Family" class="flex items-center gap-2 px-3 py-2 rounded-md text-sm font-medium @btnGhostClass">
                            <i data-lucide="user"></i> Família
                        </a>
                        <a asp-controller="Student" asp-action="Transactions" class="flex items-center gap-2 px-3 py-2 rounded-md text-sm font-medium @btnGhostClass">
                            <i data-lucide="file-text"></i> Lançamentos
                        </a>
                        <a asp-controller="Student" asp-action="Challenges" class="flex items-center gap-2 px-3 py-2 rounded-md text-sm font-medium @btnGhostClass">
                            <i data-lucide="target"></i> Desafios
                        </a>
                    }
                    else if (User.IsInRole("Professor"))
                    {
                        <a asp-controller="Professor" asp-action="Dashboard" class="flex items-center gap-2 px-3 py-2 rounded-md text-sm font-medium @btnGhostClass">
                            <i data-lucide="graduation-cap"></i> Turmas
                        </a>
                        <a asp-controller="Professor" asp-action="Challenges" class="flex items-center gap-2 px-3 py-2 rounded-md text-sm font-medium @btnGhostClass">
                            <i data-lucide="target"></i> Desafios
                        </a>
                    }
                    else if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Admin" asp-action="Dashboard" class="flex items-center gap-2 px-3 py-2 rounded-md text-sm font-medium @btnGhostClass">
                            <i data-lucide="settings"></i> Administração
                        </a>
                    }

                    <div class="relative group ml-4">
                        <button class="flex items-center gap-2 px-3 py-2 rounded-md text-sm font-medium @btnGhostClass">
                            <i data-lucide="user"></i> @User.Identity.Name
                        </button>
                        
                        <div class="absolute right-0 w-48 pt-2 hidden group-hover:block z-50">
                            <div class="bg-white border rounded-md shadow-xl text-gray-800 py-2">
                                <div class="px-4 py-2 border-b font-medium text-xs uppercase tracking-wider text-gray-400">Minha Conta</div>
                                <form asp-controller="Auth" asp-action="Logout" method="post">
                                    <button type="submit" class="w-full text-left px-4 py-2 hover:bg-gray-100 flex items-center gap-2 text-red-600 transition-colors">
                                        <i data-lucide="log-out"></i> Sair
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </nav>
            }
            else
            {
                <div class="flex gap-2">
                    <a asp-controller="Auth" asp-action="Login" class="px-4 py-2 rounded-md text-sm font-medium @(isLight ? "bg-white text-primary" : "border hover:bg-gray-50")">
                        Entrar
                    </a>
                    <a asp-controller="Auth" asp-action="Register" class="px-4 py-2 rounded-md text-sm font-medium @(isLight ? "bg-white text-primary" : "bg-primary text-white hover:bg-primary/90")">
                        Registar
                    </a>
                </div>
            }
        </div>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https:
    <script src="https:
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            lucide.createIcons();
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

