@{
    ViewData["Title"] = "Início";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DEC - Dinheiro em Casa - ISTEC</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .hero {
            min-height: 100vh;
            background: linear-gradient(135deg, #0C73B7, #2da7df);
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            color: white;
            padding: 2rem;
        }

        .hero-content {
            max-width: 800px;
        }

        .hero h1 {
            font-size: 3rem;
            color: white;
            margin-bottom: 1rem;
        }

        .hero p {
            font-size: 1.25rem;
            margin-bottom: 2rem;
            opacity: 0.95;
        }

        .hero-logo {
            margin-bottom: 2rem;
        }

        .hero-logo img {
            max-width: 250px;
            height: auto;
        }

        .hero-buttons {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .hero-buttons .btn {
            padding: 1rem 2.5rem;
            font-size: 1.1rem;
        }

        .features {
            padding: 4rem 2rem;
            background: white;
        }

        .features-grid {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
        }

        .feature {
            text-align: center;
            padding: 2rem;
        }

        .feature-icon {
            font-size: 3rem;
            margin-bottom: 1rem;
        }

        .feature h3 {
            margin-bottom: 1rem;
        }

        @@media (max-width: 768px) {
            .hero h1 {
                font-size: 2rem;
            }
            .hero p {
                font-size: 1rem;
            }
        }
    </style>
</head>
<body>
    <div class="hero">
        <div class="hero-content">
            <div class="hero-logo">
                <img src="~/images/d5218954818f0b46d89a04972d9ea1b2b5f28bba.png" alt="ISTEC Logo" />
            </div>
            <h1>DEC - Dinheiro em Casa</h1>
            <p>Plataforma de Literacia Financeira para Alunos do Ensino Secundário</p>
            <p>Aprende a gerir o orçamento familiar através de simulações reais e desafios pedagógicos</p>

            <div class="hero-buttons">
                <a class="btn btn-primary" asp-controller="Home" asp-action="Login">Entrar</a>
                <a class="btn btn-secondary" asp-controller="Home" asp-action="Register">Registar</a>
            </div>
        </div>
    </div>

    <div class="features">
        <div class="features-grid">
            <div class="feature">
                <div class="feature-icon">👨‍👩‍👧‍👦</div>
                <h3>Famílias Virtuais</h3>
                <p>Cria e gere cenários familiares realistas com rendimentos, despesas e poupanças</p>
            </div>

            <div class="feature">
                <div class="feature-icon">📊</div>
                <h3>Simulações Financeiras</h3>
                <p>Explora juros compostos, amortização de crédito e projeções com inflação</p>
            </div>

            <div class="feature">
                <div class="feature-icon">🎯</div>
                <h3>Desafios Pedagógicos</h3>
                <p>Completa desafios criados pelos professores e ganha badges de conquista</p>
            </div>

            <div class="feature">
                <div class="feature-icon">📈</div>
                <h3>Taxa de Esforço</h3>
                <p>Aprende a calcular e otimizar a taxa de esforço das famílias</p>
            </div>

            <div class="feature">
                <div class="feature-icon">💰</div>
                <h3>Gestão de Transações</h3>
                <p>Regista rendimentos e despesas fixas e variáveis de forma organizada</p>
            </div>

            <div class="feature">
                <div class="feature-icon">🏆</div>
                <h3>Sistema de Recompensas</h3>
                <p>Ganha pontos e badges ao completar desafios e atingir objetivos</p>
            </div>
        </div>
    </div>
</body>
</html>
