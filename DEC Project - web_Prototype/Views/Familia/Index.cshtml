@model List<DEC.Models.Familia>

@{
    ViewData["Title"] = "Minhas Famílias";
}

<div class="container">
    <div class="flex justify-between align-center mb-3">
        <h1>Minhas Famílias</h1>
        <a class="btn btn-primary" asp-action="Create">+ Nova Família</a>
    </div>

    @if (Model != null && Model.Any())
    {
        @foreach (var familia in Model)
        {
            <div class="familia-card">
                <div class="familia-header">
                    <div>
                        <h3 style="margin-bottom: 0.5rem;">@familia.Nome</h3>
                        <p style="color: #666; margin-bottom: 0.5rem;">@familia.Descricao</p>
                        <div style="display: flex; gap: 1rem; font-size: 0.875rem; color: #666;">
                            <span>👨‍👩‍👧‍👦 @familia.NumeroAdultos adultos, @familia.NumeroCriancas crianças</span>
                            <span>📅 Criada em @familia.DataCriacao.ToString("dd/MM/yyyy")</span>
                            @if (familia.Ativa)
                            {
                                <span class="badge badge-success">Ativa</span>
                            }
                            else
                            {
                                <span class="badge badge-warning">Inativa</span>
                            }
                        </div>
                    </div>
                    <div>
                        @{
                            var taxaClass = familia.TaxaEsforco < 30 ? "taxa-boa" :
                                           familia.TaxaEsforco < 40 ? "taxa-media" : "taxa-alta";
                        }
                        <div class="taxa-esforco @taxaClass">@familia.TaxaEsforco%</div>
                        <small style="display: block; text-align: center; color: #666;">Taxa de Esforço</small>
                    </div>
                </div>

                <div class="grid-3 mb-2" style="padding: 1rem; background: #f8f9fa; border-radius: 8px;">
                    <div>
                        <small style="color: #666;">Rendimento Mensal</small>
                        <div style="font-weight: 600; color: #28a745; font-size: 1.2rem;">@familia.RendimentoMensal.ToString("C")</div>
                    </div>
                    <div>
                        <small style="color: #666;">Despesas Totais</small>
                        <div style="font-weight: 600; color: #dc3545; font-size: 1.2rem;">@((familia.DespesasFixas + familia.DespesasVariaveis).ToString("C"))</div>
                    </div>
                    <div>
                        <small style="color: #666;">Poupança</small>
                        <div style="font-weight: 600; color: #0C73B7; font-size: 1.2rem;">@familia.Poupanca.ToString("C")</div>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.5rem; margin-bottom: 1rem; font-size: 0.875rem;">
                    <div>
                        <span style="color: #666;">Despesas Fixas:</span>
                        <strong>@familia.DespesasFixas.ToString("C")</strong>
                    </div>
                    <div>
                        <span style="color: #666;">Despesas Variáveis:</span>
                        <strong>@familia.DespesasVariaveis.ToString("C")</strong>
                    </div>
                </div>

                <div class="flex gap-1">
                    <a class="btn btn-primary btn-small" asp-action="Details" asp-route-id="@familia.Id">Ver Detalhes</a>
                    <a class="btn btn-secondary btn-small" asp-controller="Simulacao" asp-action="Index" asp-route-familiaId="@familia.Id">Simulações</a>
                    <a class="btn btn-secondary btn-small" asp-action="Edit" asp-route-id="@familia.Id">Editar</a>
                    @if (!familia.Ativa)
                    {
                        <form asp-action="Delete" asp-route-id="@familia.Id" method="post" style="display: inline;" onsubmit="return confirm('Tem a certeza que deseja eliminar esta família?');">
                            <button type="submit" class="btn btn-danger btn-small">Eliminar</button>
                        </form>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <div class="card" style="text-align: center; padding: 4rem;">
            <h3 style="color: #666; margin-bottom: 1rem;">Ainda não tens famílias criadas</h3>
            <p style="color: #999; margin-bottom: 2rem;">Cria a tua primeira família para começar a gerir o orçamento familiar</p>
            <a class="btn btn-primary" asp-action="Create">Criar a Primeira Família</a>
        </div>
    }
</div>
