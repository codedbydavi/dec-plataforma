@model Frontend.Models.ViewModels.ScenarioDetailsViewModel
@using System.Text.Json
@using Frontend.Models.DTOs

@{
    ViewData["Title"] = $"Cenário: {Model.Scenario.FamilyName}";
    var scenario = Model.Scenario;
    var lastResult = Model.LatestResult;
}

<div class="max-w-7xl mx-auto p-6">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">@TempData["SuccessMessage"]</span>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">@TempData["ErrorMessage"]</span>
        </div>
    }

    
    <div class="flex items-center justify-between mb-6">
        <div>
            <nav class="flex text-sm text-gray-500 mb-2">
                <a asp-action="Dashboard" class="hover:text-primary transition-colors">Dashboard</a>
                <span class="mx-2">/</span>
                <span class="text-gray-900 font-medium">@scenario.FamilyName</span>
            </nav>
            <h1 class="text-3xl font-bold flex items-center gap-2">
                <i data-lucide="home" class="w-6 h-6 text-primary"></i> @scenario.FamilyName
            </h1>
            <p class="text-sm text-gray-500 mt-1">Criado a @scenario.CreatedAt.ToString("dd/MM/yyyy")</p>
        </div>
        <div class="flex items-center gap-4">
            <div class="text-right">
                <p class="text-sm text-gray-500">Saldo Inicial</p>
                <p class="text-2xl font-bold text-gray-900">€@scenario.InitialBalance.ToString("N2")</p>
            </div>
            <button data-modal-target="editScenarioModal" class="p-2 border rounded-md hover:bg-gray-50 text-gray-600 transition-colors" title="Editar Cenário">
                <i data-lucide="pencil" class="w-5 h-5"></i>
            </button>
        </div>
    </div>

    
    @if (lastResult != null)
    {
        @if (lastResult.CreditSimulation != null)
        {
            <div class="bg-blue-50 border border-blue-200 text-blue-800 px-4 py-3 rounded-md mb-4 flex items-center gap-3">
                <i data-lucide="banknote" class="w-5 h-5 text-blue-600"></i>
                <div class="text-sm">
                    <strong>Simulação de Crédito Ativa:</strong> Prestação Mensal: <span class="font-bold">€@lastResult.CreditSimulation.MonthlyInstallment.ToString("N2")</span> | 
                    Custo Total: <span class="font-bold">€@lastResult.CreditSimulation.TotalCost.ToString("N2")</span> 
                    (Juros: €@lastResult.CreditSimulation.TotalInterest.ToString("N2"))
                </div>
            </div>
        }

        @if (lastResult.SavingsSimulation != null)
        {
            <div class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-md mb-4 flex items-center gap-3">
                <i data-lucide="piggy-bank" class="w-5 h-5 text-green-600"></i>
                <div class="text-sm">
                    <strong>Projeção de Poupança Ativa:</strong> Valor Final Projetado: <span class="font-bold">€@lastResult.SavingsSimulation.FinalAmount.ToString("N2")</span>
                </div>
            </div>
        }

        @if (lastResult.CashFlowSimulation != null)
        {
            <div class="bg-yellow-50 border border-yellow-200 text-yellow-800 px-4 py-3 rounded-md mb-4 flex items-center gap-3">
                <i data-lucide="trending-up" class="w-5 h-5 text-yellow-600"></i>
                <div class="text-sm">
                    <strong>Fluxo de Caixa (com Inflação):</strong> Poupança Acumulada no Fim do Prazo: <span class="font-bold">€@lastResult.CashFlowSimulation.CumulativeSavings.ToString("N2")</span>
                </div>
            </div>
        }

        
        <div class="grid md:grid-cols-4 gap-4 mb-8">
            <div class="bg-primary text-white rounded-xl p-6 shadow-sm">
                <p class="text-sm text-white/80 uppercase tracking-wider mb-2">Saldo Mensal Real</p>
                <div class="text-3xl font-bold">€@lastResult.Summary.MonthlyBalance.ToString("N2")</div>
            </div>

            <div class="bg-white rounded-xl border p-6 shadow-sm">
                <p class="text-sm text-gray-500 uppercase tracking-wider mb-2">Taxa de Esforço</p>
                <div class="text-3xl font-bold flex items-center gap-2 @(lastResult.Summary.EffortRatePercentage > 40 ? "text-red-600" : "text-green-600")">
                    @lastResult.Summary.EffortRatePercentage.ToString("F1")%
                </div>
                <div class="w-full bg-gray-200 rounded-full h-1.5 mt-3">
                    <div class="@(lastResult.Summary.EffortRatePercentage > 40 ? "bg-red-500" : "bg-green-500") h-1.5 rounded-full" style="width: @Math.Min(lastResult.Summary.EffortRatePercentage, 100)%"></div>
                </div>
            </div>

            <div class="bg-white rounded-xl border p-6 shadow-sm">
                <p class="text-sm text-gray-500 uppercase tracking-wider mb-2">Projeção a 12 Meses</p>
                <div class="text-3xl font-bold text-gray-900">€@lastResult.Projections.BalanceAfter12Months.ToString("N2")</div>
            </div>

            <div class="bg-white rounded-xl border p-6 shadow-sm">
                <p class="text-sm text-gray-500 uppercase tracking-wider mb-2">Sustentabilidade</p>
                <div class="text-2xl font-bold flex items-center gap-2 @(lastResult.Projections.IsSustainable ? "text-green-600" : "text-red-600")">
                    @if(lastResult.Projections.IsSustainable) {
                        <i data-lucide="check-circle" class="w-6 h-6"></i> <text>Sustentável</text>
                    } else {
                        <i data-lucide="alert-triangle" class="w-6 h-6"></i> <text>Em Risco</text>
                    }
                </div>
            </div>
        </div>
    }

    
    <div class="mb-6 border-b border-gray-200">
        <ul class="flex flex-wrap -mb-px text-sm font-medium text-center" id="myTab" role="tablist">
            <li class="mr-2" role="presentation">
                <button class="inline-block p-4 border-b-2 border-primary text-primary rounded-t-lg active" id="data-tab" data-tabs-target="#data" type="button" role="tab">
                    <i data-lucide="list" class="w-4 h-4 inline mr-2"></i> Dados
                </button>
            </li>
            <li class="mr-2" role="presentation">
                <button class="inline-block p-4 border-b-2 border-transparent hover:text-gray-600 hover:border-gray-300 rounded-t-lg" id="dashboard-tab" data-tabs-target="#dashboard" type="button" role="tab">
                    <i data-lucide="pie-chart" class="w-4 h-4 inline mr-2"></i> Dashboard Gráfico
                </button>
            </li>
        </ul>
    </div>

    <div id="myTabContent">
        
        <div class="p-4 rounded-lg space-y-6" id="data" role="tabpanel">
            <div class="grid lg:grid-cols-3 gap-6">
                
                <div class="lg:col-span-2 bg-white rounded-xl border shadow-sm flex flex-col">
                    <div class="p-4 border-b flex justify-between items-center bg-gray-50/50 rounded-t-xl">
                        <h3 class="font-bold text-lg flex items-center gap-2">
                            <i data-lucide="file-text" class="text-primary w-5 h-5"></i> Lançamentos Financeiros
                        </h3>
                        <button data-modal-target="addEntryModal" class="px-3 py-1.5 bg-primary text-white text-sm font-medium rounded hover:bg-primary/90 flex items-center gap-1">
                            <i data-lucide="plus" class="w-4 h-4"></i> Adicionar
                        </button>
                    </div>
                    <div class="flex-1 overflow-auto max-h-[400px]">
                        @if (!scenario.Entries.Any())
                        {
                            <div class="p-8 text-center text-gray-500">
                                <i data-lucide="clipboard-list" class="w-12 h-12 mx-auto mb-3 opacity-20"></i>
                                <p>Nenhum lançamento registado.</p>
                            </div>
                        }
                        else
                        {
                            <table class="w-full text-sm text-left">
                                <thead class="bg-gray-50 text-gray-500 uppercase sticky top-0">
                                    <tr>
                                        <th class="px-4 py-3 font-medium">Tipo</th>
                                        <th class="px-4 py-3 font-medium">Categoria</th>
                                        <th class="px-4 py-3 font-medium text-right">Valor</th>
                                        <th class="px-4 py-3 font-medium text-center">Mês</th>
                                        <th class="px-4 py-3 font-medium text-center">Recorrente</th>
                                        <th class="px-4 py-3 font-medium text-right">Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var entry in scenario.Entries.OrderBy(e => int.TryParse(e.Month, out var m) ? m : 0))
                                    {
                                        <tr class="border-b last:border-b-0 hover:bg-gray-50">
                                            <td class="px-4 py-3">
                                                @if (entry is Frontend.Models.Entities.Income)
                                                { <span class="bg-green-100 text-green-800 text-xs font-medium px-2 py-0.5 rounded">Rendimento</span> }
                                                else
                                                { <span class="bg-red-100 text-red-800 text-xs font-medium px-2 py-0.5 rounded">Despesa</span> }
                                            </td>
                                            <td class="px-4 py-3 text-gray-700">@(entry.Category?.Name ?? "Geral")</td>
                                            <td class="px-4 py-3 font-bold text-right">€@entry.Amount.ToString("N2")</td>
                                            <td class="px-4 py-3 text-center text-gray-600">@entry.Month</td>
                                            <td class="px-4 py-3 text-center">
                                                @if (entry.Recurrence != "None" && entry.Recurrence != "False" && entry.Recurrence != "0")
                                                { <i data-lucide="repeat" class="w-4 h-4 mx-auto text-primary" title="Sim"></i> }
                                                else
                                                { <span class="text-gray-400">—</span> }
                                            </td>
                                            <td class="px-4 py-3 text-right">
                                                <div class="flex justify-end gap-2">
                                                    <button onclick="openEditEntryModal(@entry.Id, @entry.TypeId, @entry.CategoryId, @entry.Amount.ToString().Replace(",", "."), '@entry.Month', @((entry.Recurrence != "None" && entry.Recurrence != "False" && entry.Recurrence != "0") ? "true" : "false"))" class="p-1 text-blue-600 hover:bg-blue-50 rounded transition-colors" title="Editar">
                                                        <i data-lucide="edit-2" class="w-4 h-4"></i>
                                                    </button>
                                                    <form asp-action="DeleteEntry" method="post" onsubmit="event.preventDefault(); showConfirmModal(this, 'Tem a certeza que deseja remover este lançamento? Esta ação não pode ser desfeita.')" class="inline">
                                                        <input type="hidden" name="id" value="@entry.Id" />
                                                        <button type="submit" class="p-1 text-red-600 hover:bg-red-50 rounded transition-colors" title="Remover">
                                                            <i data-lucide="trash-2" class="w-4 h-4"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>

                
                <div class="space-y-6">
                    
                    <div class="bg-white rounded-xl border shadow-sm">
                        <div class="p-4 border-b flex justify-between items-center bg-gray-50/50 rounded-t-xl">
                            <h3 class="font-bold text-lg flex items-center gap-2">
                                <i data-lucide="target" class="text-green-600 w-5 h-5"></i> Objetivos
                            </h3>
                            <button data-modal-target="addObjectiveModal" class="px-2 py-1 border border-green-600 text-green-600 rounded hover:bg-green-50">
                                <i data-lucide="plus" class="w-4 h-4"></i>
                            </button>
                        </div>
                        <div class="p-0 max-h-[250px] overflow-auto">
                            @if (!scenario.Objectives.Any())
                            {
                                <div class="p-6 text-center text-gray-500 text-sm">Nenhum objetivo definido.</div>
                            }
                            else
                            {
                                <ul class="divide-y">
                                    @foreach (var obj in scenario.Objectives)
                                    {
                                        var analysis = lastResult?.ObjectivesAnalysis.FirstOrDefault(a => a.Description == obj.Description);
                                        <li class="p-4 hover:bg-gray-50 group">
                                            <div class="flex justify-between items-center mb-1">
                                                <div class="flex items-center gap-2">
                                                    <span class="font-bold text-sm text-gray-900">@obj.Description</span>
                                                    <form asp-action="DeleteObjective" method="post" onsubmit="event.preventDefault(); showConfirmModal(this, 'Deseja remover este objetivo?')" class="opacity-0 group-hover:opacity-100 transition-opacity">
                                                        <input type="hidden" name="id" value="@obj.Id" />
                                                        <button type="submit" class="text-red-400 hover:text-red-600">
                                                            <i data-lucide="x-circle" class="w-4 h-4"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                                <span class="font-bold text-sm text-green-600">€@obj.TargetValue.ToString("N2")</span>
                                            </div>
                                            <div class="flex justify-between items-center text-xs">
                                                <span class="text-gray-500">Em @obj.TargetMonths meses</span>
                                                @if (analysis != null)
                                                {
                                                    <span class="@(analysis.IsAttainable ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800") px-2 py-0.5 rounded font-medium">
                                                        @(analysis.IsAttainable ? $"Atinge em {analysis.MonthsToGoal}m" : "Inatingível")
                                                    </span>
                                                }
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }
                        </div>
                    </div>

                    
                    <div class="bg-white rounded-xl border border-gray-200 shadow-sm text-center p-6">
                        <div class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center mx-auto mb-3">
                            <i data-lucide="cpu" class="w-6 h-6 text-primary"></i>
                        </div>
                        <h4 class="font-bold text-lg text-gray-900 mb-4">Motor de Cálculo</h4>
                        
                        <form asp-action="RunSimulation" method="post" class="mb-3">
                            <input type="hidden" name="scenarioId" value="@scenario.Id" />
                            <button type="submit" class="w-full bg-primary hover:bg-primary/90 text-white font-medium py-2.5 rounded-md flex items-center justify-center gap-2 transition-colors shadow-sm mb-3">
                                <i data-lucide="play" class="w-4 h-4"></i> Correr Simulação Base
                            </button>
                        </form>
                        
                        <div class="space-y-2">
                            <button data-modal-target="creditSimModal" class="w-full bg-white border border-gray-300 text-gray-700 hover:bg-blue-50 font-medium py-2 rounded-md flex items-center justify-center gap-2 transition-colors text-sm shadow-sm">
                                <i data-lucide="credit-card" class="w-4 h-4 text-blue-600"></i> Simular Cenário c/ Crédito
                            </button>
                            
                            <button data-modal-target="savingsSimModal" class="w-full bg-white border border-gray-300 text-gray-700 hover:bg-green-50 font-medium py-2 rounded-md flex items-center justify-center gap-2 transition-colors text-sm shadow-sm">
                                <i data-lucide="piggy-bank" class="w-4 h-4 text-green-600"></i> Simular Plano de Poupança
                            </button>

                            <button data-modal-target="cashFlowSimModal" class="w-full bg-white border border-gray-300 text-gray-700 hover:bg-yellow-50 font-medium py-2 rounded-md flex items-center justify-center gap-2 transition-colors text-sm shadow-sm">
                                <i data-lucide="trending-up" class="w-4 h-4 text-yellow-600"></i> Simular c/ Inflação
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            
            <div class="bg-white rounded-xl border shadow-sm mt-6">
                <div class="p-4 border-b bg-gray-50/50 rounded-t-xl">
                    <h3 class="font-bold text-lg flex items-center gap-2">
                        <i data-lucide="history" class="text-gray-600 w-5 h-5"></i> Histórico de Simulações
                    </h3>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-sm text-left">
                        <thead class="bg-gray-50 text-gray-500 uppercase">
                            <tr>
                                <th class="px-6 py-3 font-medium">Data / Hora</th>
                                <th class="px-6 py-3 font-medium">Saldo (12m)</th>
                                <th class="px-6 py-3 font-medium">Taxa de Esforço</th>
                                <th class="px-6 py-3 font-medium text-center">Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!scenario.Histories.Any())
                            {
                                <tr><td colspan="4" class="px-6 py-8 text-center text-gray-500">Nenhum histórico disponível.</td></tr>
                            }
                            else
                            {
                                @foreach (var history in scenario.Histories.OrderByDescending(h => h.ExecutionDate))
                                {
                                    <tr class="border-b last:border-b-0 hover:bg-gray-50">
                                        <td class="px-6 py-4 text-gray-600">@history.ExecutionDate.ToString("g")</td>
                                        <td class="px-6 py-4 font-bold text-gray-900">€@history.FinalBalance.ToString("N2")</td>
                                        <td class="px-6 py-4">
                                            <span class="px-2 py-1 rounded text-xs font-bold @(history.EffortRate > 40 ? "bg-red-100 text-red-800" : "bg-green-100 text-green-800")">
                                                @history.EffortRate.ToString("F1")%
                                            </span>
                                        </td>
                                        <td class="px-6 py-4 text-center">
                                            @if (history.EffortRate <= 40)
                                            { <span class="text-green-600 flex items-center justify-center gap-1 text-xs font-bold"><i data-lucide="check-circle" class="w-4 h-4"></i> Sustentável</span> }
                                            else
                                            { <span class="text-red-600 flex items-center justify-center gap-1 text-xs font-bold"><i data-lucide="alert-triangle" class="w-4 h-4"></i> Em Risco</span> }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        
        <div class="hidden p-4 rounded-lg" id="dashboard" role="tabpanel">
            @if (lastResult == null)
            {
                <div class="bg-white rounded-xl border p-16 text-center shadow-sm">
                    <i data-lucide="bar-chart-2" class="w-16 h-16 mx-auto mb-4 text-gray-300"></i>
                    <h4 class="text-xl font-bold text-gray-700 mb-2">Sem Dados de Simulação</h4>
                    <p class="text-gray-500">Corre uma simulação para gerar os gráficos interativos.</p>
                </div>
            }
            else
            {
                <div class="grid md:grid-cols-2 gap-6">
                    <div class="bg-white rounded-xl border shadow-sm p-6">
                        <h3 class="font-bold text-lg mb-4 text-center text-gray-800">Rendimentos vs Despesas</h3>
                        <div class="h-[300px] w-full relative">
                            <canvas id="chartIncomeExpenses"></canvas>
                        </div>
                    </div>
                    
                    <div class="bg-white rounded-xl border shadow-sm p-6">
                        <h3 class="font-bold text-lg mb-4 text-center text-gray-800">Projeção de Saldo (12 Meses)</h3>
                        <div class="h-[300px] w-full relative">
                            <canvas id="chartProjection"></canvas>
                        </div>
                    </div>

                    <div class="md:col-span-2 bg-white rounded-xl border shadow-sm p-6">
                        <h3 class="font-bold text-lg mb-4 text-gray-800">Análise da Taxa de Esforço</h3>
                        <div class="h-[120px] w-full relative">
                            <canvas id="chartEffortRate"></canvas>
                        </div>
                        <p class="text-center text-sm text-gray-500 mt-2 flex items-center justify-center gap-1">
                            <i data-lucide="info" class="w-4 h-4"></i> Uma taxa de esforço saudável deve manter-se abaixo dos 40%.
                        </p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>


<div id="addEntryModal" class="hidden fixed inset-0 bg-black/50 z-[100] flex items-center justify-center">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-lg overflow-hidden">
        <div class="px-6 py-4 border-b flex justify-between items-center">
            <h3 class="text-lg font-bold">Novo Lançamento Financeiro</h3>
            <button type="button" class="text-gray-400 hover:text-gray-600" onclick="document.getElementById('addEntryModal').classList.add('hidden')"><i data-lucide="x" class="w-5 h-5"></i></button>
        </div>
        <div class="p-6">
            <partial name="_AddEntryForm" model="Model.AddEntry" />
        </div>
    </div>
</div>


<div id="addObjectiveModal" class="hidden fixed inset-0 bg-black/50 z-[100] flex items-center justify-center">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-lg overflow-hidden">
        <form asp-action="AddObjective" method="post">
            <input type="hidden" name="ScenarioId" value="@scenario.Id" />
            <div class="px-6 py-4 border-b flex justify-between items-center bg-green-50/50">
                <h3 class="text-lg font-bold text-green-800">Novo Objetivo de Poupança</h3>
                <button type="button" class="text-gray-400 hover:text-gray-600" onclick="document.getElementById('addObjectiveModal').classList.add('hidden')"><i data-lucide="x" class="w-5 h-5"></i></button>
            </div>
            <div class="p-6 space-y-4">
                <div>
                    <label class="block text-sm font-medium mb-1">Descrição</label>
                    <input name="Description" type="text" class="w-full border rounded-md px-3 py-2 focus:ring-green-500/50" placeholder="Ex: Comprar Carro" required />
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium mb-1">Valor Alvo (€)</label>
                        <input name="TargetValue" type="number" step="0.01" class="w-full border rounded-md px-3 py-2 focus:ring-green-500/50" required />
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1">Prazo (Meses)</label>
                        <input name="TargetMonths" type="number" min="1" class="w-full border rounded-md px-3 py-2 focus:ring-green-500/50" required />
                    </div>
                </div>
            </div>
            <div class="px-6 py-4 bg-gray-50 flex justify-end gap-3">
                <button type="button" onclick="document.getElementById('addObjectiveModal').classList.add('hidden')" class="px-4 py-2 border rounded-md hover:bg-gray-100 font-medium text-gray-700">Cancelar</button>
                <button type="submit" class="px-4 py-2 bg-green-600 text-white rounded-md hover:bg-green-700 font-medium">Gravar Objetivo</button>
            </div>
        </form>
    </div>
</div>


<div id="creditSimModal" class="hidden fixed inset-0 bg-black/50 z-[100] flex items-center justify-center">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-lg overflow-hidden">
        <form asp-action="RunSimulation" method="post">
            <input type="hidden" name="scenarioId" value="@scenario.Id" />
            <div class="px-6 py-4 border-b flex justify-between items-center bg-blue-50/50">
                <h3 class="text-lg font-bold text-blue-800">Simular "What-If" com Crédito</h3>
                <button type="button" class="text-gray-400 hover:text-gray-600" onclick="document.getElementById('creditSimModal').classList.add('hidden')"><i data-lucide="x" class="w-5 h-5"></i></button>
            </div>
            <div class="p-6 space-y-4">
                <p class="text-sm text-gray-500">Veja o impacto que um novo empréstimo teria no seu orçamento mensal e na sua taxa de esforço.</p>
                <div>
                    <label class="block text-sm font-medium mb-1">Montante do Empréstimo (€)</label>
                    <input name="LoanSimulation.Principal" type="number" step="0.01" class="w-full border rounded-md px-3 py-2 focus:ring-blue-500/50" required />
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium mb-1">Taxa Anual (TAN %)</label>
